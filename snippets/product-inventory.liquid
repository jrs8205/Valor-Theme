{%- comment -%}
  Renders inventory status for the currently selected variant with colored
  dot + status label. Three states: in stock, low stock, out of stock.

  Only shown when the variant has Shopify-tracked inventory and the policy is
  "deny" (i.e. real stock counts that matter to the customer). The outer
  wrapper always renders (carrying a stable, section-scoped id and `hidden`
  when not shown) so the variant Section-Rendering swap always has a
  destination; the inner <p> carries the per-variant state class, so swapping
  innerHTML updates the colored dot too.

  Accepts:
    variant       {Variant}  required
    block         {Block}    required — for settings.inventory_threshold,
                                        settings.show_inventory_quantity,
                                        shopify_attributes
    section_id    {String}   optional — for the section-scoped fragment id
    class_prefix  {String}   optional — 'valor-mp' (default) or 'valor-fp'
{%- endcomment -%}

{%- liquid
  assign prefix = class_prefix | default: 'valor-mp'
  assign show_inv = false
  if variant.inventory_management == 'shopify' and variant.inventory_policy == 'deny'
    assign show_inv = true
  endif
  if show_inv
    if variant.inventory_quantity <= 0
      assign inv_class = prefix | append: '__inventory--out'
      assign inv_text = 'product.out_of_stock' | t
    elsif variant.inventory_quantity <= block.settings.inventory_threshold
      assign inv_class = prefix | append: '__inventory--low'
      if block.settings.show_inventory_quantity
        assign inv_text = 'product.low_stock_count' | t: count: variant.inventory_quantity
      else
        assign inv_text = 'product.low_stock' | t
      endif
    else
      assign inv_class = prefix | append: '__inventory--in'
      assign inv_text = 'product.in_stock' | t
    endif
  endif
-%}
<div
  id="ProductInventory-{{ section_id }}"
  class="{{ prefix }}__inventory-wrap"
  {% unless show_inv %}hidden{% endunless %}
  {{ block.shopify_attributes }}
>
  {%- if show_inv -%}
    <p class="{{ prefix }}__inventory {{ inv_class }}">
      <span class="{{ prefix }}__inventory-dot" aria-hidden="true"></span>
      {{ inv_text }}
    </p>
  {%- endif -%}
</div>
