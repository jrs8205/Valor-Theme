{%- comment -%}
  Renders product price (current + compare-at + sale badge + unit price + tax note).

  The price div carries a stable, section-scoped id so the variant
  Section-Rendering swap (product-info.js) can replace its innerHTML on
  variant change — Liquid stays the single source of truth for money
  formatting (no client-side formatMoney).

  Accepts:
    variant       {Variant}  required — the currently selected variant
    block         {Block}    optional — used for shopify_attributes
    section_id    {String}   optional — for the section-scoped fragment id
    class_prefix  {String}   optional — 'valor-mp' (default) or 'valor-fp'

  Used by:
    sections/main-product.liquid
    sections/featured-product.liquid
{%- endcomment -%}

{%- liquid
  assign prefix = class_prefix | default: 'valor-mp'
  assign attrs = ''
  assign price_font_size = 24
  if block
    assign attrs = block.shopify_attributes
    assign price_font_size = block.settings.price_font_size | default: 24
  endif
  assign compare_price_font_size = price_font_size | times: 0.75 | round
-%}

<div
  id="ProductPrice-{{ section_id }}"
  class="{{ prefix }}__price"
  style="--valor-product-price-size: {{ price_font_size }}px; --valor-product-compare-price-size: {{ compare_price_font_size }}px;"
  {{ attrs }}
>
  {%- if variant.compare_at_price > variant.price -%}
    <span class="{{ prefix }}__price-current {{ prefix }}__price-current--sale">
      {{- variant.price | money -}}
    </span>
    <s class="{{ prefix }}__price-compare">
      {{- variant.compare_at_price | money -}}
    </s>
    <span class="{{ prefix }}__price-badge">{{ 'product.sale' | t }}</span>
  {%- else -%}
    <span class="{{ prefix }}__price-current">
      {{- variant.price | money -}}
    </span>
  {%- endif -%}
</div>
{%- render 'product-unit-price',
  variant: variant,
  class_name: prefix | append: '__unit-price',
  wrapper_id: 'ProductUnitPrice-' | append: section_id
-%}
{%- if cart.taxes_included -%}
  <p class="{{ prefix }}__tax">{{ 'product.include_taxes' | t }}</p>
{%- endif -%}
