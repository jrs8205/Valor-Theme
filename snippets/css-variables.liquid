{%- liquid
  # Pre-compute body font variants. font_modify is more expressive than
  # accessing font.variants directly, but it can return nil for fonts that
  # don't have the requested variant — fall back to the base font in those
  # cases so we always have a usable variable.
  assign body_font = settings.type_body_font
  assign body_font_bold = body_font | font_modify: 'weight', 'bold' | default: body_font
  assign body_font_italic = body_font | font_modify: 'style', 'italic' | default: body_font
  assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic' | default: body_font_bold

  assign heading_font = settings.type_header_font
  assign heading_font_bold = heading_font | font_modify: 'weight', 'bold' | default: heading_font
  assign heading_font_italic = heading_font | font_modify: 'style', 'italic' | default: heading_font
  assign heading_font_bold_italic = heading_font_bold | font_modify: 'style', 'italic' | default: heading_font_bold

  assign button_bg_normalized = settings.button_background_color | downcase | strip | remove: ' '
  assign button_text_normalized = settings.button_text_color | downcase | strip | remove: ' '
  assign button_border_normalized = settings.button_border_color | downcase | strip | remove: ' '
  assign button_hover_bg_normalized = settings.button_hover_background_color | downcase | strip | remove: ' '
  assign button_hover_text_normalized = settings.button_hover_text_color | downcase | strip | remove: ' '
  assign button_hover_border_normalized = settings.button_hover_border_color | downcase | strip | remove: ' '
  assign button_outline_text_normalized = settings.button_outline_text_color | downcase | strip | remove: ' '
  assign button_outline_hover_text_normalized = settings.button_outline_hover_text_color | downcase | strip | remove: ' '

  assign button_bg_is_set = false
  if settings.button_background_color != blank and button_bg_normalized != 'transparent' and button_bg_normalized != 'rgba(0,0,0,0)'
    assign button_bg_is_set = true
  endif

  assign button_text_is_set = false
  if settings.button_text_color != blank and button_text_normalized != 'transparent' and button_text_normalized != 'rgba(0,0,0,0)'
    assign button_text_is_set = true
  endif

  assign button_border_is_set = false
  if settings.button_border_color != blank and button_border_normalized != 'transparent' and button_border_normalized != 'rgba(0,0,0,0)'
    assign button_border_is_set = true
  endif

  assign button_hover_bg_is_set = false
  if settings.button_hover_background_color != blank and button_hover_bg_normalized != 'transparent' and button_hover_bg_normalized != 'rgba(0,0,0,0)'
    assign button_hover_bg_is_set = true
  endif

  assign button_hover_text_is_set = false
  if settings.button_hover_text_color != blank and button_hover_text_normalized != 'transparent' and button_hover_text_normalized != 'rgba(0,0,0,0)'
    assign button_hover_text_is_set = true
  endif

  assign button_hover_border_is_set = false
  if settings.button_hover_border_color != blank and button_hover_border_normalized != 'transparent' and button_hover_border_normalized != 'rgba(0,0,0,0)'
    assign button_hover_border_is_set = true
  endif

  assign button_outline_text_is_set = false
  if settings.button_outline_text_color != blank and button_outline_text_normalized != 'transparent' and button_outline_text_normalized != 'rgba(0,0,0,0)'
    assign button_outline_text_is_set = true
  endif

  assign button_outline_hover_text_is_set = false
  if settings.button_outline_hover_text_color != blank and button_outline_hover_text_normalized != 'transparent' and button_outline_hover_text_normalized != 'rgba(0,0,0,0)'
    assign button_outline_hover_text_is_set = true
  endif
-%}

{% style %}
  /* Body font variants — bold and italic are common in prose, so we load
     them up-front to avoid the synthesised-bold artefacts the browser
     produces when the real variant isn't loaded. */
  {{ body_font | font_face: font_display: 'swap' }}
  {{ body_font_bold | font_face: font_display: 'swap' }}
  {{ body_font_italic | font_face: font_display: 'swap' }}
  {{ body_font_bold_italic | font_face: font_display: 'swap' }}

  /* Heading font variants — same four variants, so <em> inside headings
     uses a real italic glyph rather than the browser's faux-italic slant. */
  {{ heading_font | font_face: font_display: 'swap' }}
  {{ heading_font_bold | font_face: font_display: 'swap' }}
  {{ heading_font_italic | font_face: font_display: 'swap' }}
  {{ heading_font_bold_italic | font_face: font_display: 'swap' }}

  :root {
    /* Body font tokens */
    --font-body--family: {{ body_font.family }}, {{ body_font.fallback_families }};
    --font-body--style: {{ body_font.style }};
    --font-body--weight: {{ body_font.weight }};
    --font-body--weight-bold: {{ body_font_bold.weight }};

    /* Heading font tokens */
    --font-heading--family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --font-heading--style: {{ heading_font.style }};
    --font-heading--weight: {{ heading_font.weight }};
    --font-heading--weight-bold: {{ heading_font_bold.weight }};

    /* Type scales.
       Body scale is applied to the root font size (html element) in
       critical.css, so changing body_scale rescales every rem-based
       size in the theme together — fonts, paddings, line-heights.
       Heading scale is *relative to body_scale*, mirroring Dawn:
       this prevents body_scale from unintentionally changing heading
       sizes, while heading_scale controls headings independently.
       Example: body 130, heading 100 → headings keep their intended 100% scale,
                body 100, heading 150 → headings are 50% larger than body. */
    --font-body-scale: {{ settings.body_scale | divided_by: 100.0 }};
    --font-heading-scale: {{ settings.heading_scale | times: 1.0 | divided_by: settings.body_scale }};

    /* Centralised typography scale.
       Heading sizes are calc()-multiplied by --font-heading-scale so the
       Theme Editor's "Font size scale" setting still works. The clamp()
       values use modern fluid typography: a hard floor on small viewports,
       a smooth interpolation across the middle, and a hard ceiling on
       wide screens — set with `clamp(min, base + slope*vw, max)`.

       Body sizes are plain rem values. Because critical.css scales
       <html> font-size by --font-body-scale, every rem here is already
       multiplied by the body scale — no double-scaling needed. */
    --font-size-heading-xs:      calc(var(--font-heading-scale, 1) * clamp(0.875rem, 0.84rem + 0.18vw, 1rem));
    --font-size-heading-sm:      calc(var(--font-heading-scale, 1) * clamp(1rem,     0.96rem + 0.22vw, 1.125rem));
    --font-size-heading-md:      calc(var(--font-heading-scale, 1) * clamp(1.125rem, 1.02rem + 0.55vw, 1.5rem));
    --font-size-heading-lg:      calc(var(--font-heading-scale, 1) * clamp(1.5rem,   1.36rem + 0.75vw, 2rem));
    --font-size-heading-xl:      calc(var(--font-heading-scale, 1) * clamp(2rem,     1.78rem + 1.10vw, 2.75rem));
    --font-size-heading-2xl:     calc(var(--font-heading-scale, 1) * clamp(2.5rem,   2.15rem + 1.75vw, 3.75rem));
    --font-size-heading-display: calc(var(--font-heading-scale, 1) * clamp(3rem,     2.40rem + 3.00vw, 5rem));

    --font-size-body-2xs:  0.75rem;
    --font-size-body-xs:   0.8125rem;
    --font-size-body-sm:   0.875rem;
    --font-size-body-md:   0.9375rem;
    --font-size-body-base: 1rem;
    --font-size-body-lg:   1.125rem;

    /* Layout */
    --page-width: {{ settings.max_page_width }};
    --page-margin: {{ settings.min_page_margin }}px;

    /* Colors — static fallbacks only. The real values come from the
       color-scheme blocks emitted after this rule (the first scheme also
       targets :root, making it the page default). Kept so the theme never
       renders unstyled if the scheme list were ever empty. */
    --color-background: #FFFFFF;
    --color-foreground: #333333;

    /* Buttons — the scheme-INDEPENDENT button tokens. Explicit button
       color settings always win; blank or transparent background settings
       stay transparent. The tokens whose fallback chain ends in the
       scheme's background/text colors live in the per-scheme blocks
       below — custom properties resolve var() at the element that
       declares them, so a :root-level var(--color-foreground) fallback
       would bake the first scheme's colors into every scheme. */
    --color-button-bg:                     {%- if button_bg_is_set -%}{{ settings.button_background_color }}{%- else -%}transparent{%- endif -%};
    --color-button-hover-bg:               {%- if button_hover_bg_is_set -%}{{ settings.button_hover_background_color }}{%- elsif button_bg_is_set -%}{{ settings.button_background_color }}{%- else -%}transparent{%- endif -%};
    --color-button-outline-hover-bg:       {%- if button_hover_bg_is_set -%}{{ settings.button_hover_background_color }}{%- elsif button_bg_is_set -%}{{ settings.button_background_color }}{%- else -%}transparent{%- endif -%};
    {%- if button_hover_bg_is_set or button_hover_text_is_set or button_hover_border_is_set or button_outline_hover_text_is_set %}
    --button-hover-opacity: 1;
    {%- else %}
    --button-hover-opacity: 0.85;
    {%- endif %}
    --style-button-border-width:   {{ settings.button_border_width }}px;
    --style-border-radius-buttons: {{ settings.button_corner_radius }}px;

    /* Borders & dividers — three opacity levels for visual hierarchy.

       --valor-border-subtle:  decorative inner lines (cards, list rows,
                                input internal borders). Visible on close
                                inspection but doesn't compete for attention.
       --valor-border-default: structural page dividers (header, footer,
                                filter bar, cart totals). Should be clearly
                                visible without dominating the layout.
       --valor-border-strong:  interactive surfaces (mobile accordions,
                                expand-collapse rows). Reads as a tappable
                                separator on touch devices where 1px on
                                a high-DPR mobile screen is easy to miss
                                with lower opacity. */
    --valor-border-subtle:  color-mix(in srgb, var(--color-foreground) 16%, transparent);
    --valor-border-default: color-mix(in srgb, var(--color-foreground) 24%, transparent);
    --valor-border-strong:  var(--color-foreground);

    /* Status colors — semantic colors used to communicate success/error
       across the theme. Hardcoded rather than tied to --color-foreground
       because their meaning (red = error, green = success) must remain
       consistent regardless of how the merchant configures the theme.

       --valor-color-error:   error states, validation messages, danger badges
       --valor-color-warning: low-stock and caution states
       --valor-color-success: success states, savings, in-stock confirmations */
    --valor-color-error:   #b91c1c;
    --valor-color-warning: #d49000;
    --valor-color-success: #15803d;

    /* Inputs */
    --style-border-radius-inputs: {{ settings.input_corner_radius }}px;
  }

  /* Color schemes — one block per scheme defined in Theme settings >
     Colors. The first scheme also targets :root, making it the page-level
     default; sections opt into other schemes via their "Color scheme"
     setting, which puts a .color-<scheme-id> class on the section root.
     All component CSS reads var(--color-background)/var(--color-foreground),
     so it needs no scheme awareness.

     Derived tokens (borders) and the scheme-dependent button fallbacks are
     re-declared per scheme with literal Liquid values: a custom property
     resolves var() references at the element that declares it, so a single
     :root declaration could not follow the enclosing scheme class. */
  {% for scheme in settings.color_schemes -%}
  {% if forloop.first %}:root,
  {% endif -%}
  .color-{{ scheme.id }} {
    --color-background: {{ scheme.settings.background }};
    --color-foreground: {{ scheme.settings.text }};

    --valor-border-subtle:  color-mix(in srgb, {{ scheme.settings.text }} 16%, transparent);
    --valor-border-default: color-mix(in srgb, {{ scheme.settings.text }} 24%, transparent);
    --valor-border-strong:  {{ scheme.settings.text }};

    --color-button-text:                   {%- if button_text_is_set -%}{{ settings.button_text_color }}{%- elsif button_bg_is_set -%}{{ scheme.settings.background }}{%- else -%}{{ scheme.settings.text }}{%- endif -%};
    --color-button-border:                 {%- if button_border_is_set -%}{{ settings.button_border_color }}{%- elsif button_bg_is_set -%}{{ settings.button_background_color }}{%- else -%}{{ scheme.settings.text }}{%- endif -%};
    --color-button-hover-text:             {%- if button_hover_text_is_set -%}{{ settings.button_hover_text_color }}{%- elsif button_text_is_set -%}{{ settings.button_text_color }}{%- elsif button_hover_bg_is_set or button_bg_is_set -%}{{ scheme.settings.background }}{%- else -%}{{ scheme.settings.text }}{%- endif -%};
    --color-button-hover-border:           {%- if button_hover_border_is_set -%}{{ settings.button_hover_border_color }}{%- elsif button_hover_bg_is_set -%}{{ settings.button_hover_background_color }}{%- elsif button_border_is_set -%}{{ settings.button_border_color }}{%- elsif button_bg_is_set -%}{{ settings.button_background_color }}{%- else -%}{{ scheme.settings.text }}{%- endif -%};
    --color-button-outline-text:           {%- if button_outline_text_is_set -%}{{ settings.button_outline_text_color }}{%- elsif button_border_is_set -%}{{ settings.button_border_color }}{%- elsif button_bg_is_set -%}{{ settings.button_background_color }}{%- else -%}{{ scheme.settings.text }}{%- endif -%};
    --color-button-outline-border:         {%- if button_border_is_set -%}{{ settings.button_border_color }}{%- elsif button_bg_is_set -%}{{ settings.button_background_color }}{%- else -%}{{ scheme.settings.text }}{%- endif -%};
    --color-button-outline-hover-text:     {%- if button_outline_hover_text_is_set -%}{{ settings.button_outline_hover_text_color }}{%- elsif button_hover_text_is_set -%}{{ settings.button_hover_text_color }}{%- elsif button_hover_bg_is_set or button_bg_is_set -%}{{ scheme.settings.background }}{%- else -%}{{ scheme.settings.text }}{%- endif -%};
    --color-button-outline-hover-border:   {%- if button_hover_border_is_set -%}{{ settings.button_hover_border_color }}{%- elsif button_hover_bg_is_set -%}{{ settings.button_hover_background_color }}{%- elsif button_border_is_set -%}{{ settings.button_border_color }}{%- elsif button_bg_is_set -%}{{ settings.button_background_color }}{%- else -%}{{ scheme.settings.text }}{%- endif -%};
  }
  {% endfor %}

  /* Mobile page margin override. Desktop uses --page-margin above; on small
     viewports the merchant can set a separate, usually tighter, side margin.
     Overriding the custom property on :root cascades to every .shopify-section
     grid that reads var(--page-margin). */
  @media screen and (max-width: 749px) {
    :root {
      --page-margin: {{ settings.min_page_margin_mobile | default: 16 }}px;
    }
  }
{% endstyle %}
