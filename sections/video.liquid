{%- comment -%}
  Video section.

  Supports:
    - Shopify-hosted video (uploaded via theme editor)
    - External video URL (YouTube, Vimeo, or any direct MP4/WebM/MOV URL)

  Layout:
    - Heading above the video (style follows Dawn convention)
    - Video plays inline, optional play/pause toggle button
    - Optional cover image shown until first play (only when play button on)
    - Width: Small / Medium / Large / Full width
    - Mobile can override to full width independently
    - Optional hero-style overlay content on top of the video
      (Heading / Subheading / Buttons blocks + position, dim, text box)
{%- endcomment -%}

{%- liquid
  assign shopify_video = section.settings.video
  assign external_url = section.settings.video_url
  assign mobile_shopify_video = section.settings.mobile_video
  assign mobile_external_url = section.settings.mobile_video_url

  # Detect whether a separate mobile video is configured
  assign has_mobile_video = false
  if mobile_shopify_video != blank or mobile_external_url != blank
    assign has_mobile_video = true
  endif

  # Pre-compute boolean values for video_tag filter arguments.
  # Liquid filter arguments must be plain values, not comparison expressions.
  assign autoplay_video = false
  if section.settings.show_play_button == false
    assign autoplay_video = true
  endif

  assign video_muted = section.settings.mute_audio
  if autoplay_video
    assign video_muted = true
  endif

  # Pre-compute alt text for cover image (filter chains in argument values
  # are fragile — especially default with multiple fallbacks).
  assign cover_alt = section.settings.video_alt
  if cover_alt == blank
    assign cover_alt = section.settings.cover_image.alt
  endif
  if cover_alt == blank
    assign cover_alt = section.settings.heading
  endif
  assign cover_alt = cover_alt | escape

  assign mobile_cover_alt = section.settings.video_alt
  if mobile_cover_alt == blank
    assign mobile_cover_alt = section.settings.mobile_cover_image.alt
  endif
  if mobile_cover_alt == blank
    assign mobile_cover_alt = section.settings.heading
  endif
  assign mobile_cover_alt = mobile_cover_alt | escape

  # Detect external video provider (desktop)
  assign provider = ''
  if external_url != blank
    assign url_str = external_url | downcase
    if url_str contains 'youtube.com' or url_str contains 'youtu.be'
      assign provider = 'youtube'
    elsif url_str contains 'vimeo.com'
      assign provider = 'vimeo'
    else
      assign provider = 'direct'
    endif
  endif

  # Detect external video provider (mobile)
  assign mobile_provider = ''
  if mobile_external_url != blank
    assign mobile_url_str = mobile_external_url | downcase
    if mobile_url_str contains 'youtube.com' or mobile_url_str contains 'youtu.be'
      assign mobile_provider = 'youtube'
    elsif mobile_url_str contains 'vimeo.com'
      assign mobile_provider = 'vimeo'
    else
      assign mobile_provider = 'direct'
    endif
  endif

  # Resolve YouTube video id (desktop)
  if provider == 'youtube'
    assign yt_id = ''
    if external_url contains 'youtu.be/'
      assign yt_id = external_url | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first
    elsif external_url contains 'watch?v='
      assign yt_id = external_url | split: 'watch?v=' | last | split: '&' | first
    elsif external_url contains '/embed/'
      assign yt_id = external_url | split: '/embed/' | last | split: '?' | first | split: '&' | first
    endif
  endif

  # Resolve YouTube video id (mobile)
  if mobile_provider == 'youtube'
    assign mobile_yt_id = ''
    if mobile_external_url contains 'youtu.be/'
      assign mobile_yt_id = mobile_external_url | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first
    elsif mobile_external_url contains 'watch?v='
      assign mobile_yt_id = mobile_external_url | split: 'watch?v=' | last | split: '&' | first
    elsif mobile_external_url contains '/embed/'
      assign mobile_yt_id = mobile_external_url | split: '/embed/' | last | split: '?' | first | split: '&' | first
    endif
  endif

  # Resolve Vimeo video id (numeric)
  if provider == 'vimeo'
    assign vimeo_id = external_url | split: 'vimeo.com/' | last | split: '?' | first | split: '/' | first
  endif

  if mobile_provider == 'vimeo'
    assign mobile_vimeo_id = mobile_external_url | split: 'vimeo.com/' | last | split: '?' | first | split: '/' | first
  endif

  # Use cover image only when play button is enabled.
  assign use_cover = false
  if section.settings.show_play_button and section.settings.cover_image != blank
    assign use_cover = true
  endif

  assign use_mobile_cover = false
  if section.settings.show_play_button and section.settings.mobile_cover_image != blank
    assign use_mobile_cover = true
  endif

  # Width modifier
  assign width = section.settings.width

  assign use_transparent_header_trigger = false
  if request.page_type == 'index' and section.settings.enable_transparent_header
    assign use_transparent_header_trigger = true
  endif

  assign use_full_width_desktop = false
  if width == 'full' or use_transparent_header_trigger
    assign use_full_width_desktop = true
  endif

  assign use_full_width_mobile = section.settings.full_width_mobile
  if use_transparent_header_trigger
    assign use_full_width_mobile = true
  endif
-%}

<div
  class="color-{{ section.settings.color_scheme }} valor-video valor-video--{{ width }}{% if use_full_width_desktop %} valor-video--full{% endif %}{% if use_full_width_mobile %} valor-video--full-mobile{% endif %}{% if use_transparent_header_trigger %} valor-transparent-header-trigger{% endif %}{% if has_mobile_video %} valor-video--has-mobile{% endif %}"
  style="--valor-section-padding-top: {{ section.settings.padding_top }}px; --valor-section-padding-bottom: {{ section.settings.padding_bottom }}px; --valor-video-dim: {{ section.settings.overlay_opacity | times: 0.01 }};"
  {% if use_transparent_header_trigger %}
    data-transparent-header-behavior="{{ section.settings.transparent_header_behavior | default: 'always' }}"
  {% endif %}
>
  {%- if use_transparent_header_trigger -%}
    {% render 'transparent-header-trigger', transparent_header_behavior: section.settings.transparent_header_behavior %}
  {%- endif -%}
  <div class="valor-video__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="valor-video__heading valor-heading valor-heading--{{ section.settings.heading_size }} valor-video__heading--align-{{ section.settings.heading_alignment }}">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    <div class="valor-video__stage">
      <valor-video
        class="valor-video__frame valor-video__frame--desktop"
        data-show-play-button="{{ section.settings.show_play_button }}"
        data-loop="{{ section.settings.loop }}"
        data-mute="{{ section.settings.mute_audio }}"
        data-provider="{{ provider }}"
      >
        {%- if use_cover -%}
          <div class="valor-video__cover" data-video-cover>
            {{
              section.settings.cover_image
              | image_url: width: 1500
              | image_tag:
                widths: '400, 600, 800, 1100, 1500, 2000',
                sizes: '100vw',
                class: 'valor-video__cover-img',
                alt: cover_alt,
                loading: 'lazy'
            }}
            <button
              type="button"
              class="valor-video__play"
              data-video-play
              aria-label="{{ 'video.play' | t | default: 'Play video' }}"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>
          </div>
        {%- endif -%}

        <div
          class="valor-video__media"
          data-video-media
          {% if use_cover %}
            hidden
          {% endif %}
        >
          {%- if shopify_video != blank -%}
            {{
              shopify_video
              | video_tag:
                class: 'valor-video__el',
                controls: false,
                muted: video_muted,
                autoplay: autoplay_video,
                loop: section.settings.loop,
                playsinline: true,
                preload: 'metadata',
                image_size: '1500x'
            }}
          {%- elsif provider == 'youtube' and yt_id != blank -%}
            {%- liquid
              assign yt_params = 'rel=0&modestbranding=1&playsinline=1&enablejsapi=1'
              if section.settings.show_play_button == false
                assign yt_params = yt_params | append: '&autoplay=1&mute=1&controls=0'
                if section.settings.loop
                  assign yt_params = yt_params | append: '&loop=1&playlist=' | append: yt_id
                endif
              endif
            -%}
            <iframe
              class="valor-video__el valor-video__el--iframe"
              src="https://www.youtube.com/embed/{{ yt_id }}?{{ yt_params }}"
              title="{{ section.settings.video_alt | default: section.settings.heading | escape }}"
              frameborder="0"
              allow="autoplay; encrypted-media; picture-in-picture"
              allowfullscreen
              loading="lazy"
              data-yt-iframe
            ></iframe>
          {%- elsif provider == 'vimeo' and vimeo_id != blank -%}
            {%- liquid
              assign vimeo_params = 'dnt=1&playsinline=1'
              if section.settings.show_play_button == false
                assign vimeo_params = vimeo_params | append: '&autoplay=1&muted=1&background=1'
                if section.settings.loop
                  assign vimeo_params = vimeo_params | append: '&loop=1'
                endif
              endif
            -%}
            <iframe
              class="valor-video__el valor-video__el--iframe"
              src="https://player.vimeo.com/video/{{ vimeo_id }}?{{ vimeo_params }}"
              title="{{ section.settings.video_alt | default: section.settings.heading | escape }}"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          {%- elsif provider == 'direct' -%}
            <video
              class="valor-video__el"
              src="{{ external_url }}"
              {% unless section.settings.show_play_button %}
                autoplay muted
              {% endunless %}
              {% if section.settings.loop %}
                loop
              {% endif %}
              playsinline
              preload="metadata"
              {% if section.settings.show_play_button %}
                controls
              {% endif %}
            ></video>
          {%- else -%}
            <div class="valor-video__placeholder">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'valor-video__placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.show_play_button and use_cover == false and shopify_video != blank -%}
          {%- comment -%}
            Shopify-hosted video without a cover image: still allow toggling
            play/pause via an overlay button (no autoplay). Hidden once the
            video starts and reappears on pause.
          {%- endcomment -%}
          <button
            type="button"
            class="valor-video__play valor-video__play--overlay"
            data-video-toggle
            aria-label="{{ 'video.play' | t | default: 'Play video' }}"
          >
            <svg
              class="valor-video__play-icon valor-video__play-icon--play"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              focusable="false"
            >
              <path d="M8 5v14l11-7z"/>
            </svg>
            <svg
              class="valor-video__play-icon valor-video__play-icon--pause"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              focusable="false"
            >
              <path d="M6 5h4v14H6zM14 5h4v14h-4z"/>
            </svg>
          </button>
        {%- endif -%}
      </valor-video>

      {%- if has_mobile_video -%}
        <valor-video
          class="valor-video__frame valor-video__frame--mobile valor-video__frame--aspect-{{ section.settings.mobile_aspect }}"
          data-show-play-button="{{ section.settings.show_play_button }}"
          data-loop="{{ section.settings.loop }}"
          data-mute="{{ section.settings.mute_audio }}"
          data-provider="{{ mobile_provider }}"
        >
          {%- if use_mobile_cover -%}
            <div class="valor-video__cover" data-video-cover>
              {{
                section.settings.mobile_cover_image
                | image_url: width: 1100
                | image_tag:
                  widths: '400, 600, 800, 1100, 1500',
                  sizes: '100vw',
                  class: 'valor-video__cover-img',
                  alt: mobile_cover_alt,
                  loading: 'lazy'
              }}
              <button
                type="button"
                class="valor-video__play"
                data-video-play
                aria-label="{{ 'video.play' | t | default: 'Play video' }}"
              >
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </button>
            </div>
          {%- endif -%}

          <div
            class="valor-video__media"
            data-video-media
            {% if use_mobile_cover %}
              hidden
            {% endif %}
          >
            {%- if mobile_shopify_video != blank -%}
              {{
                mobile_shopify_video
                | video_tag:
                  class: 'valor-video__el',
                  controls: false,
                  muted: video_muted,
                  autoplay: autoplay_video,
                  loop: section.settings.loop,
                  playsinline: true,
                  preload: 'metadata',
                  image_size: '1100x'
              }}
            {%- elsif mobile_provider == 'youtube' and mobile_yt_id != blank -%}
              {%- liquid
                assign m_yt_params = 'rel=0&modestbranding=1&playsinline=1&enablejsapi=1'
                if section.settings.show_play_button == false
                  assign m_yt_params = m_yt_params | append: '&autoplay=1&mute=1&controls=0'
                  if section.settings.loop
                    assign m_yt_params = m_yt_params | append: '&loop=1&playlist=' | append: mobile_yt_id
                  endif
                endif
              -%}
              <iframe
                class="valor-video__el valor-video__el--iframe"
                src="https://www.youtube.com/embed/{{ mobile_yt_id }}?{{ m_yt_params }}"
                title="{{ cover_alt }}"
                frameborder="0"
                allow="autoplay; encrypted-media; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            {%- elsif mobile_provider == 'vimeo' and mobile_vimeo_id != blank -%}
              {%- liquid
                assign m_vimeo_params = 'dnt=1&playsinline=1'
                if section.settings.show_play_button == false
                  assign m_vimeo_params = m_vimeo_params | append: '&autoplay=1&muted=1&background=1'
                  if section.settings.loop
                    assign m_vimeo_params = m_vimeo_params | append: '&loop=1'
                  endif
                endif
              -%}
              <iframe
                class="valor-video__el valor-video__el--iframe"
                src="https://player.vimeo.com/video/{{ mobile_vimeo_id }}?{{ m_vimeo_params }}"
                title="{{ cover_alt }}"
                frameborder="0"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            {%- elsif mobile_provider == 'direct' -%}
              <video
                class="valor-video__el"
                src="{{ mobile_external_url }}"
                {% unless section.settings.show_play_button %}
                  autoplay muted
                {% endunless %}
                {% if section.settings.loop %}
                  loop
                {% endif %}
                playsinline
                preload="metadata"
                {% if section.settings.show_play_button %}
                  controls
                {% endif %}
              ></video>
            {%- endif -%}
          </div>

          {%- if section.settings.show_play_button and use_mobile_cover == false and mobile_shopify_video != blank -%}
            <button
              type="button"
              class="valor-video__play valor-video__play--overlay"
              data-video-toggle
              aria-label="{{ 'video.play' | t | default: 'Play video' }}"
            >
              <svg
                class="valor-video__play-icon valor-video__play-icon--play"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M8 5v14l11-7z"/>
              </svg>
              <svg
                class="valor-video__play-icon valor-video__play-icon--pause"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M6 5h4v14H6zM14 5h4v14h-4z"/>
              </svg>
            </button>
          {%- endif -%}
        </valor-video>
      {%- endif -%}

      {%- if section.settings.overlay_opacity > 0 -%}
        <div class="valor-video__dim" aria-hidden="true"></div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="valor-video__content-wrapper valor-video__content-wrapper--pos-{{ section.settings.desktop_content_position }} valor-video__content-wrapper--align-{{ section.settings.desktop_content_alignment }} valor-video__content-wrapper--mobile-{{ section.settings.mobile_content_alignment }}">
          <div class="valor-video__content{% if section.settings.show_text_box %} valor-video__content--box{% endif %}">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'heading' -%}
                  <h2
                    class="valor-video__content-heading valor-video__content-heading--{{ block.settings.heading_size }}"
                    {% if block.settings.heading_color != blank %}
                      style="--valor-video-heading-color: {{ block.settings.heading_color }};"
                    {% endif %}
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.heading }}
                  </h2>
                {%- when 'subheading' -%}
                  <div
                    class="valor-video__content-subheading rte"
                    {% if block.settings.subheading_color != blank %}
                      style="--valor-video-subheading-color: {{ block.settings.subheading_color }};"
                    {% endif %}
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.subheading }}
                  </div>
                {%- when 'buttons' -%}
                  <div class="valor-video__buttons" {{ block.shopify_attributes }}>
                    {%- if block.settings.button_label_1 != blank and block.settings.button_link_1 != blank -%}
                      <a
                        href="{{ block.settings.button_link_1 }}"
                        class="valor-button valor-button--{{ block.settings.button_style_1 }}"
                      >
                        {{ block.settings.button_label_1 | escape }}
                      </a>
                    {%- endif -%}
                    {%- if block.settings.button_label_2 != blank and block.settings.button_link_2 != blank -%}
                      <a
                        href="{{ block.settings.button_link_2 }}"
                        class="valor-button valor-button--{{ block.settings.button_style_2 }}"
                      >
                        {{ block.settings.button_label_2 | escape }}
                      </a>
                    {%- endif -%}
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .valor-video {
    padding-top: var(--valor-section-padding-top, 56px);
    padding-bottom: var(--valor-section-padding-bottom, 56px);
    background-color: var(--color-background);
    color: var(--color-foreground);
    overflow-x: hidden;
  }
  .valor-video.valor-transparent-header-trigger {
    padding-top: 0;
  }

  .valor-video__inner {
    width: 100%;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem);
    box-sizing: border-box;
  }
  .valor-video--small .valor-video__inner {
    max-width: 50rem;
  }
  .valor-video--medium .valor-video__inner {
    max-width: 65rem;
  }
  .valor-video--large .valor-video__inner {
    max-width: 80rem;
  }
  .valor-video--full .valor-video__inner {
    max-width: none;
    padding: 0;
  }

  /* Heading above the video — section-specific margin keeps the
     video frame breathing room. Font properties (family, weight,
     line-height, letter-spacing, size) come from .valor-heading. */
  .valor-video__heading {
    margin: 0 0 1.25rem 0;
  }
  /* Heading alignment — left is default for editorial flow, center pairs
     well with full-width video sections. Inherits from text-align so it
     works regardless of width modifier. */
  .valor-video__heading--align-left {
    text-align: left;
  }
  .valor-video__heading--align-center {
    text-align: center;
  }
  .valor-video__heading--align-right {
    text-align: right;
  }

  /* Video frame — 16:9 by default, full-bleed image fills it */
  .valor-video__frame {
    /* display: block because <valor-video> is an autonomous custom element,
       which defaults to display: inline. */
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: color-mix(in srgb, var(--color-foreground) 6%, transparent);
    overflow: hidden;
  }

  /* Mobile aspect-ratio variants for the mobile frame */
  .valor-video__frame--aspect-9-16 {
    aspect-ratio: 9 / 16;
  }
  .valor-video__frame--aspect-4-5 {
    aspect-ratio: 4 / 5;
  }
  .valor-video__frame--aspect-1-1 {
    aspect-ratio: 1 / 1;
  }
  .valor-video__frame--aspect-16-9 {
    aspect-ratio: 16 / 9;
  }

  /* Hide the mobile frame on desktop, hide the desktop frame on mobile —
     but only when a separate mobile video is configured. Otherwise the
     desktop frame is shown on every viewport (no mobile video set). */
  .valor-video__frame--mobile {
    display: none;
  }
  @media (max-width: 749px) {
    .valor-video--has-mobile .valor-video__frame--desktop {
      display: none;
    }
    .valor-video--has-mobile .valor-video__frame--mobile {
      display: block;
    }
  }

  .valor-video__media,
  .valor-video__cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .valor-video__media[hidden] {
    display: none;
  }

  .valor-video__el,
  .valor-video__el--iframe,
  .valor-video__cover-img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border: 0;
  }

  .valor-video__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .valor-video__placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.4;
  }

  /* Play button — sits over cover image (or video when no cover) */
  .valor-video__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.92);
    color: #111;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    -webkit-tap-highlight-color: transparent;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    transition:
      background-color 0.15s ease,
      transform 0.15s ease;
  }
  .valor-video__play svg {
    width: 30px;
    height: 30px;
  }
  /* Play icon offset slightly right so it appears optically centered */
  .valor-video__play .valor-video__play-icon--play,
  .valor-video__cover .valor-video__play svg:not(.valor-video__play-icon--pause) {
    margin-left: 4px;
  }
  @media (hover: hover) {
    .valor-video__play:hover {
      background: #fff;
      transform: translate(-50%, -50%) scale(1.05);
    }
  }
  .valor-video__play:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 4px;
  }

  /* Toggle button on a Shopify-hosted video (no cover) — fades when paused */
  .valor-video__play--overlay {
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
  }
  .valor-video__play--overlay:hover {
    background: rgba(0, 0, 0, 0.75);
  }
  .valor-video__play-icon {
    display: inline-block;
  }
  .valor-video__play-icon--pause {
    display: none;
  }
  .valor-video__frame[data-playing='true'] .valor-video__play-icon--play {
    display: none;
  }
  .valor-video__frame[data-playing='true'] .valor-video__play-icon--pause {
    display: inline-block;
  }
  /* Auto-hide the toggle while playing; reappear on hover/focus */
  .valor-video__frame[data-playing='true'] .valor-video__play--overlay {
    opacity: 0;
    transition: opacity 0.3s ease 1s;
  }
  @media (hover: hover) {
    .valor-video__frame[data-playing='true']:hover .valor-video__play--overlay {
      opacity: 1;
      transition-delay: 0s;
    }
  }
  .valor-video__frame[data-playing='true'] .valor-video__play--overlay:focus-visible {
    opacity: 1;
  }

  /* Stage — positioning context for the overlay layers. Only one of the
     two frames is visible at a time, so a single dim + content overlay
     sits over whichever frame is currently shown. */
  .valor-video__stage {
    position: relative;
  }

  /* Darkening layer for overlay-content legibility. z-index 1 keeps it
     above the frames but below the play button and the content (both 2). */
  .valor-video__dim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: #000;
    opacity: var(--valor-video-dim, 0);
    pointer-events: none;
  }

  /* Content overlay — mirrors the hero banner. pointer-events: none lets
     clicks fall through to the play button and the video's own controls;
     the buttons and the text box restore pointer-events on themselves.
     Trade-off: overlay text is not mouse-selectable outside the box. */
  .valor-video__content-wrapper {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    padding: clamp(2rem, 5vw, 5rem) clamp(1rem, 4vw, 3rem);
    pointer-events: none;
  }

  /* Content position (vertical alignment within the stage) */
  .valor-video__content-wrapper--pos-top-left,
  .valor-video__content-wrapper--pos-top-center,
  .valor-video__content-wrapper--pos-top-right {
    align-items: flex-start;
  }
  .valor-video__content-wrapper--pos-middle-left,
  .valor-video__content-wrapper--pos-middle-center,
  .valor-video__content-wrapper--pos-middle-right {
    align-items: center;
  }
  .valor-video__content-wrapper--pos-bottom-left,
  .valor-video__content-wrapper--pos-bottom-center,
  .valor-video__content-wrapper--pos-bottom-right {
    align-items: flex-end;
  }

  /* Content position (horizontal) */
  .valor-video__content-wrapper--pos-top-left,
  .valor-video__content-wrapper--pos-middle-left,
  .valor-video__content-wrapper--pos-bottom-left {
    justify-content: flex-start;
  }
  .valor-video__content-wrapper--pos-top-center,
  .valor-video__content-wrapper--pos-middle-center,
  .valor-video__content-wrapper--pos-bottom-center {
    justify-content: center;
  }
  .valor-video__content-wrapper--pos-top-right,
  .valor-video__content-wrapper--pos-middle-right,
  .valor-video__content-wrapper--pos-bottom-right {
    justify-content: flex-end;
  }

  /* Content block */
  .valor-video__content {
    max-width: 38rem;
    color: var(--color-background);
    /* Like the hero: foreground/background flip — light text on dark video */
  }
  .valor-video__content-wrapper--align-left {
    text-align: left;
  }
  .valor-video__content-wrapper--align-center {
    text-align: center;
  }
  .valor-video__content-wrapper--align-right {
    text-align: right;
  }

  .valor-video__content--box {
    background-color: color-mix(in srgb, var(--color-background) 92%, transparent);
    color: var(--color-foreground);
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border-radius: 0.25rem;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    pointer-events: auto;
  }

  /* Overlay heading sizes — same scale as the hero banner */
  .valor-video__content-heading {
    margin: 0 0 1rem;
    color: var(--valor-video-heading-color, currentColor);
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    line-height: 1.1;
    letter-spacing: 0;
  }
  .valor-video__content-heading--h0 {
    font-size: calc(var(--font-heading-scale, 1) * clamp(2.5rem, 6vw, 5rem));
  }
  .valor-video__content-heading--h1 {
    font-size: calc(var(--font-heading-scale, 1) * clamp(2rem, 5vw, 3.75rem));
  }
  .valor-video__content-heading--h2 {
    font-size: calc(var(--font-heading-scale, 1) * clamp(1.625rem, 4vw, 2.75rem));
  }

  .valor-video__content-subheading {
    color: var(--valor-video-subheading-color, currentColor);
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.5;
    margin: 0 0 1.75rem;
    opacity: 0.95;
  }

  /* Buttons row — global .valor-button styles handle the buttons themselves */
  .valor-video__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
  }
  .valor-video__buttons .valor-button {
    pointer-events: auto;
  }
  .valor-video__content-wrapper--align-center .valor-video__buttons {
    justify-content: center;
  }
  .valor-video__content-wrapper--align-right .valor-video__buttons {
    justify-content: flex-end;
  }

  /* Mobile content alignment override */
  @media (max-width: 749px) {
    .valor-video__content-wrapper--mobile-left {
      text-align: left;
    }
    .valor-video__content-wrapper--mobile-left .valor-video__buttons {
      justify-content: flex-start;
    }
    .valor-video__content-wrapper--mobile-center {
      text-align: center;
    }
    .valor-video__content-wrapper--mobile-center .valor-video__buttons {
      justify-content: center;
    }
  }

  /* Mobile full-width override — escape the theme-shell grid */
  @media (max-width: 749px) {
    .shopify-section > .valor-video--full-mobile {
      grid-column: 1 / -1;
    }
    .valor-video--full-mobile .valor-video__inner {
      padding: 0;
      max-width: none;
    }
    .valor-video--full-mobile .valor-video__heading {
      padding: 0 clamp(1rem, 4vw, 3rem);
    }
    .valor-video__play {
      width: 60px;
      height: 60px;
    }
    .valor-video__play svg {
      width: 26px;
      height: 26px;
    }
  }

  /* Full-width on desktop — escape the theme-shell grid both viewports */
  .shopify-section > .valor-video--full {
    grid-column: 1 / -1;
  }

  @media (prefers-reduced-motion: reduce) {
    .valor-video__play,
    .valor-video__play--overlay {
      transition: none;
    }
  }
{% endstylesheet %}

