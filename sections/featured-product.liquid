    },
    {
      "type": "header",
      "content": "Gallery"
    },
    {
      "type": "select",
      "id": "enable_lightbox",
      "label": "Enable lightbox",
      "options": [
        { "value": "default", "label": "Use theme default" },
        { "value": "on", "label": "On" },
        { "value": "off", "label": "Off" }
      ],
      "default": "default",
      "info": "Click images to open a fullscreen viewer."
    },
    {
      "type": "select",
      "id": "show_thumbnails",
      "label": "Show thumbnails",
      "options": [
        { "value": "default", "label": "Use theme default" },
        { "value": "on", "label": "On" },
        { "value": "off", "label": "Off" }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "options": [
        { "value": "default", "label": "Use theme default" },
        { "value": "on", "label": "On" },
        { "value": "off", "label": "Off" }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "desktop_gallery_layout",
      "label": "Desktop gallery layout",
      "options": [
        { "value": "single", "label": "Single (main image + thumbnails)" },
        { "value": "stacked", "label": "Stacked grid" },
        { "value": "column", "label": "Single column (full width)" }
      ],
      "default": "single"
    },
    {
      "type": "select",
      "id": "mobile_indicator",
      "label": "Mobile gallery indicator",
      "options": [
        { "value": "counter", "label": "Counter" },
        { "value": "progress", "label": "Progress line" }
      ],
      "default": "counter",
      "info": "Shown on mobile only. On desktop the gallery uses thumbnails and navigation arrows instead."
    },
    {
      "type": "checkbox",
      "id": "enable_color_media_grouping",
      "default": false,
      "label": "Filter gallery images by color",
      "info": "Show only the selected color's images. Name each image's ALT text to begin with the color option value (e.g. \"Pink\", \"Pink front\"). The first color shows by default. Images whose ALT text does not begin with a color show for every color. Requires a product option detected as Color."
    },
    {
