{%- comment -%}
  Shared component styles (price, sku, vendor, inventory, quantity, rating,
  share, collapsible rows, size-guide popup) live in assets/product-info.css
  with .valor-mp__* classes. featured-product reuses those component styles for
  the blocks it shares with the main product page; its own {% stylesheet %}
  below only adds the featured-specific layout and the .valor-fp__* picker /
  price overrides. product-info.css carries no layout rules, so loading it here
  never disturbs the featured-product grid.
{%- endcomment -%}
{{ 'product-info.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign product = section.settings.product
  assign media_position = section.settings.media_position
  assign media_width = section.settings.media_width
  assign variant_style = section.settings.variant_style
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'fp-form-' | append: section.id

  # Resolve gallery overrides. Legacy 'default' values are mapped to the
  # direct section default so older saved featured-product sections keep rendering.
  assign enable_lightbox = settings.gallery_enable_lightbox
  if section.settings.enable_lightbox == 'on'
    assign enable_lightbox = true
  elsif section.settings.enable_lightbox == 'off'
    assign enable_lightbox = false
  endif

  assign show_thumbnails = settings.gallery_show_thumbnails
  if section.settings.show_thumbnails == 'on'
    assign show_thumbnails = true
  elsif section.settings.show_thumbnails == 'off'
    assign show_thumbnails = false
  endif

  assign show_arrows = settings.gallery_show_arrows
  if section.settings.show_arrows == 'on'
    assign show_arrows = true
  elsif section.settings.show_arrows == 'off'
    assign show_arrows = false
  endif

  assign mobile_indicator = section.settings.mobile_indicator | default: 'counter'
  if mobile_indicator == 'default'
    assign mobile_indicator = 'counter'
  endif

  assign media_aspect = section.settings.media_aspect_ratio | default: 'square'
  assign media_fit = section.settings.media_fit | default: 'cover'
  assign desktop_gallery_layout = section.settings.desktop_gallery_layout | default: 'single'

  # Inline size guide: when the resolved size option style is minimal or
  # boxed, a popup block set to "Inline with size option" renders next to the
  # Size label instead of as a separate block (mirrors main-product.liquid).
  assign resolved_size_style = section.settings.size_option_style | default: settings.product_size_option_style | default: 'default'
  assign use_inline_size_guide = false
  if resolved_size_style == 'minimal' or resolved_size_style == 'boxed'
    assign use_inline_size_guide = true
  endif
  assign inline_size_guide_block = null
  if use_inline_size_guide
    for candidate_block in section.blocks
      if candidate_block.type == 'popup' and candidate_block.settings.display_style == 'inline_size'
        assign inline_size_guide_block = candidate_block
        break
      endif
    endfor
  endif

  assign gallery_priority = false
  if section.index == 1 and section.location == 'template'
    assign gallery_priority = true
  endif
-%}

{%- comment -%}
  Shared variant behaviour lives in assets/product-info.js (the same
  <product-info> custom element used by sections/main-product.liquid).
  Load it here too so featured-product works on pages without a main
  product section — e.g. the homepage. The script self-guards against
  double registration (customElements.get check), so loading it on a
  product page that also has main-product is safe.
{%- endcomment -%}
<script src="{{ 'product-info.js' | asset_url }}" defer></script>

<section
  class="color-{{ section.settings.color_scheme }} valor-fp valor-fp--media-{{ media_position }} valor-fp--media-{{ media_width }}{% if section.settings.image_size_mobile == 'full' %} valor-fp--image-full-mobile{% endif %}"
  style="--valor-section-padding-top: {{ section.settings.padding_top }}px; --valor-section-padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="valor-fp__inner">
    {%- if product != blank -%}
      <div class="valor-fp__media" data-fp-gallery="{{ section.id }}">
        {%- render 'product-media-gallery',
          product: product,
          section_id: section.id,
          aspect: media_aspect,
          enable_lightbox: enable_lightbox,
          show_thumbnails: show_thumbnails,
          show_arrows: show_arrows,
          mobile_indicator: mobile_indicator,
          desktop_layout: desktop_gallery_layout,
          media_fit: media_fit,
          color_grouping: section.settings.enable_color_media_grouping,
          priority: gallery_priority
        -%}
      </div>

      <product-info
        class="valor-fp__content"
        data-prefix="valor-fp"
        data-section-id="{{ section.id }}"
        data-product-id="{{ product.id }}"
        data-product-url="{{ product.url }}"
      >
        <script type="application/json" data-product-info-i18n>
          {
            "addToCart":       {{ 'product.add_to_cart'       | t | json }},
            "soldOut":         {{ 'product.sold_out'          | t | json }},
            "sale":            {{ 'product.sale'              | t | json }},
            "sku":             {{ 'product.sku'               | t | json }},
            "inCart":          {{ 'product.in_cart'           | t | json }},
            "inCartCount":     {{ 'product.in_cart_count'     | t | json }},
            "inCartOf":        {{ 'product.in_cart_of'        | t | json }},
            "totalInCart":     {{ 'product.total_in_cart'     | t | json }},
            "inStock":         {{ 'product.in_stock'          | t | json }},
            "lowStock":        {{ 'product.low_stock'         | t | json }},
            "lowStockCount":   {{ 'product.low_stock_count'   | t | json }},
            "outOfStock":      {{ 'product.out_of_stock'      | t | json }},
            "shareLinkCopied": {{ 'product.share_link_copied' | t | json }}
          }
        </script>
        {%- form 'product', product, id: product_form_id, class: 'valor-fp__form', novalidate: 'novalidate' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id-input="{{ section.id }}">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                {%- render block -%}

              {%- when 'title' -%}
                <h2
                  class="valor-fp__title valor-heading valor-heading--{{ block.settings.heading_size }}"
                  {{ block.shopify_attributes }}
                >
                  <a href="{{ product.url }}" class="valor-fp__title-link">{{ product.title | escape }}</a>
                </h2>

              {%- when 'vendor' -%}
                {%- if product.vendor != blank -%}
                  <p
                    class="valor-fp__vendor valor-fp__vendor--{{ block.settings.text_style }}"
                    {{ block.shopify_attributes }}
                  >
                    {%- if block.settings.show_as_link -%}
                      <a href="{{ product.vendor | url_for_vendor }}">{{ product.vendor }}</a>
                    {%- else -%}
                      {{ product.vendor }}
                    {%- endif -%}
                  </p>
                {%- endif -%}

              {%- when 'text' -%}
                {%- if block.settings.text != blank -%}
                  <p
                    class="valor-mp__text valor-mp__text--{{ block.settings.text_style }}"
                    {{ block.shopify_attributes }}
                  >
                    {{- block.settings.text -}}
                  </p>
                {%- endif -%}

              {%- when 'inventory' -%}
                {%- render 'product-inventory',
                  variant: current_variant,
                  block: block,
                  section_id: section.id
                -%}

              {%- when 'sku' -%}
                {%- render 'product-sku',
                  variant: current_variant,
                  block: block,
                  section_id: section.id,
                  class_prefix: 'valor-fp'
                -%}

              {%- when 'price' -%}
                {%- render 'product-price',
                  variant: current_variant,
                  block: block,
                  section_id: section.id,
                  class_prefix: 'valor-fp'
                -%}

              {%- when 'payment_terms' -%}
                {%- render 'product-payment-terms',
                  variant: current_variant,
                  form: form,
                  block: block,
                  class_name: 'valor-fp__payment-terms'
                -%}

              {%- when 'description' -%}
                {%- render 'product-description', product: product, block: block, class_prefix: 'valor-fp' -%}

              {%- when 'custom_text' -%}
                {%- if block.settings.text != blank -%}
                  <div class="valor-fp__custom-text" {{ block.shopify_attributes }}>
                    {{ block.settings.text }}
                  </div>
                {%- endif -%}

              {%- when 'custom_liquid' -%}
                {%- if block.settings.custom_liquid != blank -%}
                  <div class="valor-fp__custom-liquid" {{ block.shopify_attributes }}>
                    {{ block.settings.custom_liquid }}
                  </div>
                {%- endif -%}

              {%- when 'variant_picker' -%}
                {%- render 'product-variant-picker',
                  product: product,
                  block: block,
                  section_id: section.id,
                  class_prefix: 'valor-fp',
                  picker_style: variant_style,
                  swatch_shape: section.settings.swatch_shape,
                  swatch_size: section.settings.swatch_size,
                  size_option_style: section.settings.size_option_style,
                  size_guide_block: inline_size_guide_block
                -%}

              {%- when 'quantity' -%}
                {%- render 'product-quantity',
                  product: product,
                  variant: current_variant,
                  block: block,
                  section_id: section.id,
                  form_id: product_form_id
                -%}

              {%- when 'buy_buttons' -%}
                {%- liquid
                  assign gift_card_recipient_enabled = false
                  if block.settings.show_gift_card_recipient and product.gift_card?
                    assign gift_card_recipient_enabled = true
                  endif

                  assign show_dynamic_checkout = block.settings.show_dynamic_checkout
                  if gift_card_recipient_enabled
                    assign show_dynamic_checkout = false
                  endif
                -%}
                <div {{ block.shopify_attributes }}>
                  {%- if gift_card_recipient_enabled -%}
                    {%- render 'product-recipient-form', product: product, form: form, section: section -%}
                  {%- endif -%}
                  <button
                    type="submit"
                    name="add"
                    class="valor-button valor-button--primary valor-fp__add"
                    data-add-button="{{ section.id }}"
                    {% unless current_variant.available %}
                      disabled
                    {% endunless %}
                  >
                    <span data-add-button-text>
                      {%- if current_variant.available -%}
                        {{ 'product.add_to_cart' | t | default: 'Add to cart' }}
                      {%- else -%}
                        {{ settings.soldout_badge_text | default: 'Sold out' }}
                      {%- endif -%}
                    </span>
                  </button>
                  {%- if show_dynamic_checkout -%}
                    {{ form | payment_button }}
                  {%- endif -%}
                </div>

              {%- when 'pickup_availability' -%}
                {%- render 'product-pickup-availability', variant: current_variant, block: block, section: section -%}

              {%- when 'rating' -%}
                {%- render 'product-rating', product: product, block: block -%}

              {%- when 'share' -%}
                {%- render 'product-share', block: block -%}

              {%- when 'collapsible_tab' -%}
                {%- render 'product-collapsible-tab', block: block -%}

              {%- when 'popup' -%}
                {%- liquid
                  assign render_popup_block = true
                  if inline_size_guide_block != blank and block.settings.display_style == 'inline_size'
                    assign render_popup_block = false
                  endif
                -%}
                {%- if render_popup_block -%}
                  {%- render 'product-popup', block: block, section_id: section.id -%}
                {%- endif -%}
            {%- endcase -%}
          {%- endfor -%}
          {%- comment -%}
            Inline error target — same convention as the main product
            page. cart-drawer.js fills this in if /cart/add.js rejects
            (out of stock, sold out, etc.).
          {%- endcomment -%}
          <div class="valor-fp__add-error" data-cart-error role="alert" hidden></div>
        {%- endform -%}
      </product-info>
    {%- else -%}
      <div class="valor-fp__media">
        <div class="valor-product-media valor-product-media--square">
          <div class="valor-product-media__main">
            <div class="valor-product-media__placeholder">
              {{ 'product-1' | placeholder_svg_tag: 'valor-product-media__placeholder-svg' }}
            </div>
          </div>
        </div>
      </div>
      <div class="valor-fp__content">
        <h2 class="valor-fp__title valor-heading valor-heading--medium">
          {{ 'sections.featured_collection.example_product' | t | default: 'Example product title' }}
        </h2>
        <div class="valor-fp__price">
          <span class="valor-fp__price-current">{{ 1999 | money }}</span>
        </div>
        <p class="valor-fp__description"><em>Select a product in the section settings.</em></p>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .valor-fp {
    padding-top: var(--valor-section-padding-top, 56px);
    padding-bottom: var(--valor-section-padding-bottom, 56px);
    background-color: var(--color-background);
    color: var(--color-foreground);
    overflow-x: hidden;
  }
  .valor-fp__inner {
    width: 100%;
    max-width: 75rem;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  /* Grid items default to min-width:auto which prevents shrinking below
     intrinsic content size. Without this, an image's natural width forces
     the grid track wider than the viewport on mobile. */
  .valor-fp__inner > * {
    min-width: 0;
  }

  /* Media — handled by product-media-gallery snippet */
  .valor-fp__media {
    width: 100%;
  }

  /* Full-width image on mobile — stretches ONLY the main image edge-to-edge,
     while thumbnails and product content stay within the section's padding.

     The theme shell wraps every section in a CSS grid where children are
     constrained to the center column (.shopify-section > * { grid-column: 2 }).
     Negative margins alone can't escape that grid, so we first promote the
     whole section to span the full grid (grid-column: 1 / -1), then use the
     classic full-bleed trick: width: 100vw + margin-left: calc(50% - 50vw).
     The section already has overflow-x: hidden as a defensive guard. */
  @media (max-width: 749px) {
    .shopify-section > .valor-fp--image-full-mobile {
      grid-column: 1 / -1;
    }

    .valor-fp--image-full-mobile .valor-product-media__main {
      width: 100vw;
      max-width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }

    .valor-fp--image-full-mobile .valor-product-media__progress {
      width: 100vw;
      max-width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }
  }

  /* Content */
  .valor-fp__content {
    display: flex;
    flex-direction: column;
  }
  .valor-fp__form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .valor-fp__title-link {
    color: inherit;
    text-decoration: none;
  }

  /* Vendor — base stays neutral; the text_style modifier (default uppercase)
     controls the visual treatment so it matches the main product page's Vendor
     block. The negative margin keeps the vendor tight to the title. */
  .valor-fp__vendor {
    font-size: 0.9375rem;
    color: color-mix(in srgb, var(--color-foreground) 85%, transparent);
    margin-bottom: -0.875rem;
  }
  .valor-fp__vendor a {
    color: inherit;
    text-decoration: none;
  }
  .valor-fp__vendor a:hover {
    text-decoration: underline;
  }
  .valor-fp__vendor--uppercase {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
  }
  .valor-fp__vendor--subtitle {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-foreground);
  }

  /* SKU */
  .valor-fp__sku {
    font-size: 0.8125rem;
    color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
    display: flex;
    gap: 0.375rem;
    align-items: baseline;
  }
  .valor-fp__sku-label {
    font-weight: 500;
  }
  .valor-fp__sku--uppercase {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }
  .valor-fp__sku--subtitle {
    font-size: 0.9375rem;
    font-weight: 500;
  }

  /* Price */
  .valor-fp__price {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.625rem;
    /* Honors the Price block's "Price font size" setting (set by
       product-price.liquid via --valor-product-price-size); falls back to the
       featured default when no block setting is present. */
    font-size: var(--valor-product-price-size, 1.125rem);
    font-weight: 500;
  }
  .valor-fp__price-current--sale {
    color: var(--valor-color-error);
  }
  .valor-fp__price-compare {
    color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
    font-size: var(--valor-product-compare-price-size, 1rem);
  }
  .valor-fp__price-badge {
    background-color: var(--color-foreground);
    color: var(--color-background);
    padding: 0.125rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: var(--font-body--weight-bold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 2px;
  }
  .valor-fp__tax-note,
  .valor-fp__tax {
    width: 100%;
    font-size: 0.8125rem;
    color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
    font-weight: var(--font-body--weight);
  }
  .valor-fp__unit-price {
    margin: -0.875rem 0 0;
    font-size: 0.8125rem;
    color: color-mix(in srgb, var(--color-foreground) 78%, transparent);
  }
  .valor-fp__payment-terms {
    font-size: 0.875rem;
    color: color-mix(in srgb, var(--color-foreground) 85%, transparent);
  }

  /* Description */
  .valor-fp__description {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-foreground) 85%, transparent);
  }
  .valor-fp__description > .rte > *:first-child {
    margin-top: 0;
  }
  .valor-fp__description > .rte > *:last-child {
    margin-bottom: 0;
  }
  .valor-fp__description-link {
    display: inline-block;
    margin-top: 0.625rem;
    color: var(--color-foreground);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }

  .valor-fp__custom-text {
    font-size: 0.875rem;
    line-height: 1.5;
    color: color-mix(in srgb, var(--color-foreground) 85%, transparent);
    padding: 0.75rem 0.875rem;
    background-color: color-mix(in srgb, var(--color-foreground) 5%, transparent);
    border-radius: var(--style-border-radius-inputs, 4px);
  }
  .valor-fp__custom-liquid {
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  /* Variant picker */
  .valor-fp__variants {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .valor-fp__option-group {
    border: none;
    padding: 0;
    margin: 0;
  }
  .valor-fp__option-label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 500;
    color: color-mix(in srgb, var(--color-foreground) 85%, transparent);
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
  }
  .valor-fp__option-selected {
    color: var(--color-foreground);
    font-weight: var(--font-body--weight-bold);
  }
  .valor-fp__option-label--size-text {
    width: 100%;
  }
  .valor-fp__option-label-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .valor-fp__option-label-text {
    min-width: 0;
  }

  /* Pills */
  .valor-fp__option-values--pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .valor-fp__option-input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    width: 0;
    height: 0;
  }
  .valor-fp__option-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    padding: 0.625rem 1rem;
    border: 1.5px solid var(--valor-border-strong);
    border-radius: 999px;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1;
    transition:
      border-color 0.15s ease,
      background-color 0.15s ease,
      color 0.15s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .valor-fp__option-input:checked + .valor-fp__option-pill {
    background-color: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }
  .valor-fp__option-input:focus-visible + .valor-fp__option-pill {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }
  /* Disabled (sold out) variants */
  .valor-fp__option-pill[data-disabled='true'] {
    opacity: 0.65;
    text-decoration: line-through;
  }

  .valor-fp__option-values--size-text {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 1.25rem;
  }
  .valor-fp__option-size-text {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.75rem;
    padding: 0.375rem 0.125rem;
    border: 0;
    border-bottom: 1px solid transparent;
    background: transparent;
    color: color-mix(in srgb, var(--color-foreground) 62%, transparent);
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.2;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .valor-fp__option-input:checked + .valor-fp__option-size-text {
    color: var(--color-foreground);
    border-bottom-color: currentColor;
  }
  .valor-fp__option-input:focus-visible + .valor-fp__option-size-text {
    outline: 2px solid var(--color-foreground);
    outline-offset: 4px;
    border-radius: 2px;
  }
  .valor-fp__option-size-text[data-disabled='true'] {
    opacity: 0.4;
    text-decoration: line-through;
    cursor: not-allowed;
  }

  /* Boxed (segmented) size selector — mirrors the main product page
     (.valor-mp__option-*--size-boxed in product-info.css). A full-width row of
     equal cells; the 1px dividers are the grid gap revealing the container
     background, so they survive wrapping. Selection, focus and sold-out reuse
     the shared .valor-fp__option-input states. */
  .valor-fp__option-label--size-boxed {
    width: 100%;
  }
  .valor-fp__option-values--size-boxed {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(3rem, 1fr));
    gap: 1px;
    background-color: var(--valor-border-default);
    border: 1px solid var(--valor-border-strong);
    border-radius: var(--style-border-radius-inputs, 4px);
    overflow: hidden;
  }
  .valor-fp__option-size-box {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 0.5rem;
    background-color: var(--color-background);
    color: var(--color-foreground);
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1;
    text-align: center;
    transition:
      background-color 0.15s ease,
      color 0.15s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .valor-fp__option-input:checked + .valor-fp__option-size-box {
    background-color: var(--color-foreground);
    color: var(--color-background);
  }
  .valor-fp__option-input:focus-visible + .valor-fp__option-size-box {
    /* Inset so the ring isn't clipped by the container's overflow:hidden */
    outline: 2px solid var(--color-foreground);
    outline-offset: -3px;
  }
  .valor-fp__option-size-box[data-disabled='true'] {
    color: color-mix(in srgb, var(--color-foreground) 35%, transparent);
    text-decoration: line-through;
    cursor: not-allowed;
  }

  /* Swatches */
  .valor-fp__option-values--swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }
  .valor-fp__option-swatch {
    position: relative;
    display: inline-block;
    width: var(--valor-swatch-size);
    height: var(--valor-swatch-size);
    border-radius: 50%;
    border: 1.5px solid var(--valor-border-strong);
    background-color: var(--valor-swatch-color, transparent);
    background-image: var(--valor-swatch-image, none);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    cursor: pointer;
    transition:
      border-color 0.15s ease,
      transform 0.15s ease;
    -webkit-tap-highlight-color: transparent;
    flex-shrink: 0;
  }
  .valor-fp__option-values--swatches-circle {
    --valor-swatch-size: 36px;
  }
  .valor-fp__option-values--swatches-circle .valor-fp__option-swatch {
    border-radius: 50%;
  }
  .valor-fp__option-values--swatches-square {
    --valor-swatch-size: 36px;
  }
  .valor-fp__option-values--swatches-square .valor-fp__option-swatch {
    border-radius: var(--style-border-radius-inputs, 4px);
  }
  @media (hover: hover) and (pointer: fine) {
    .valor-fp__option-swatch:hover {
      border-color: color-mix(in srgb, var(--color-foreground) 75%, transparent);
    }
  }
  .valor-fp__option-input:checked + .valor-fp__option-swatch {
    border-color: var(--color-background);
    box-shadow: 0 0 0 2px var(--color-foreground);
  }
  .valor-fp__option-input:focus-visible + .valor-fp__option-swatch {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }
  .valor-fp__option-swatch[data-disabled='true'] {
    opacity: 0.65;
    cursor: not-allowed;
  }
  .valor-fp__option-swatch[data-disabled='true']::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      to bottom right,
      transparent calc(50% - 1px),
      var(--color-foreground) calc(50% - 1px),
      var(--color-foreground) calc(50% + 1px),
      transparent calc(50% + 1px)
    );
    pointer-events: none;
  }

  /* Dropdown */
  .valor-fp__option-select {
    width: 100%;
    padding: 0.75rem 0.875rem;
    border: 1.5px solid var(--valor-border-strong);
    border-radius: var(--style-border-radius-inputs, 4px);
    background-color: var(--color-background);
    color: var(--color-foreground);
    font: inherit;
    font-size: 0.9375rem;
    cursor: pointer;
    appearance: none;
    background-image:
      linear-gradient(45deg, transparent 50%, currentColor 50%),
      linear-gradient(135deg, currentColor 50%, transparent 50%);
    background-position:
      calc(100% - 18px) calc(50% - 2px),
      calc(100% - 13px) calc(50% - 2px);
    background-size: 5px 5px;
    background-repeat: no-repeat;
    padding-right: 2rem;
  }
  .valor-fp__option-select:focus {
    outline: none;
    border-color: var(--color-foreground);
  }

  /* Quantity — rendered by snippets/product-quantity.liquid using the shared
     .valor-mp__quantity* component styles in product-info.css (so the Quantity
     selector style setting works identically to the main product page). No
     featured-specific quantity CSS is needed here. */

  /* Buy buttons — Add to cart and dynamic checkout (Shop Pay/PayPal/GPay) */
  .valor-fp__add {
    width: 100%;
    min-height: 52px;
    padding: 1rem 1.5rem;
    font-size: 0.9375rem;
  }
  .valor-fp__add:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  /* Inline error shown by cart-drawer.js when /cart/add.js rejects a
     request — same pattern as the main product page. Hidden via the
     [hidden] attribute until cart-drawer.js fills it in. */
  .valor-fp__add-error {
    margin-top: 0.75rem;
    padding: 0.75rem 0.9rem;
    border-left: 3px solid var(--valor-color-error);
    background-color: color-mix(in srgb, var(--valor-color-error) 8%, transparent);
    color: var(--valor-color-error);
    font-size: 0.875rem;
    line-height: 1.4;
    border-radius: 0 var(--style-border-radius-inputs, 4px) var(--style-border-radius-inputs, 4px) 0;
  }
  /* Shopify renders dynamic checkout buttons inside .shopify-payment-button.
     Force them to match Add to cart in size (Shopify defaults to a smaller pill). */
  .valor-fp__form .shopify-payment-button {
    width: 100%;
    margin-top: 0.625rem;
  }
  .valor-fp__form .shopify-payment-button__button {
    width: 100% !important;
    min-height: 52px !important;
    padding: 1rem 1.5rem !important;
    border-radius: var(--style-border-radius-buttons, var(--style-border-radius-inputs, 4px)) !important;
    font-size: 0.9375rem !important;
    font-weight: var(--font-body--weight-bold) !important;
    line-height: 1.2 !important;
  }
  .valor-fp__form .shopify-payment-button__more-options {
    margin-top: 0.5rem;
    font-size: 0.8125rem;
  }

  /* Desktop: side-by-side */
  @media (min-width: 750px) {
    .valor-fp__inner {
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 5rem);
      align-items: start;
    }
    /* Image right (text first in DOM) */
    .valor-fp--media-right .valor-fp__media {
      order: 2;
    }

    /* Width variants */
    .valor-fp--media-small.valor-fp--media-left .valor-fp__inner {
      grid-template-columns: 1fr 2fr;
    }
    .valor-fp--media-small.valor-fp--media-right .valor-fp__inner {
      grid-template-columns: 2fr 1fr;
    }
    .valor-fp--media-large.valor-fp--media-left .valor-fp__inner {
      grid-template-columns: 2fr 1fr;
    }
    .valor-fp--media-large.valor-fp--media-right .valor-fp__inner {
      grid-template-columns: 1fr 2fr;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .valor-fp__option-pill,
    .valor-fp__option-size-text,
    .valor-fp__option-size-box,
    .valor-fp__option-swatch {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured product",
  "tag": "section",
  "class": "valor-section-featured-product",
  "settings": [
    {
      "type": "color_scheme",
