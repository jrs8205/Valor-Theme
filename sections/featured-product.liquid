      "default": "cover",
      "info": "Cover fills the frame and crops if needed. Contain shows the whole image with letterboxing. Has no visible effect with Adapt aspect ratio."
    },
    {
      "type": "select",
      "id": "image_size_mobile",
      "label": "Image size (mobile)",
