{%- liquid
  assign desktop_position = section.settings.desktop_content_position
  assign content_alignment = section.settings.content_alignment
-%}
<section
  class="color-{{ section.settings.color_scheme }} valor-rich-text valor-rich-text--pos-{{ desktop_position }} valor-rich-text--align-{{ content_alignment }}{% if section.settings.full_width %} valor-rich-text--full-width{% endif %}"
  style="--valor-section-padding-top: {{ section.settings.padding_top }}px; --valor-section-padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="valor-rich-text__inner">
    <div class="valor-rich-text__content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h2
              class="valor-rich-text__heading valor-heading valor-heading--{{ block.settings.heading_size }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.heading }}
            </h2>
          {%- when 'caption' -%}
            <div
              class="valor-rich-text__caption valor-rich-text__caption--{{ block.settings.text_size }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.caption | escape }}
            </div>
          {%- when 'text' -%}
            <div class="valor-rich-text__text rte" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>
          {%- when 'buttons' -%}
            <div class="valor-rich-text__buttons" {{ block.shopify_attributes }}>
              {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
                <a
                  href="{{ block.settings.button_link }}"
                  class="valor-button valor-button--{{ block.settings.button_style }}"
                >
                  {{ block.settings.button_label | escape }}
                </a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank and block.settings.button_link_2 != blank -%}
                <a
                  href="{{ block.settings.button_link_2 }}"
                  class="valor-button valor-button--{{ block.settings.button_style_2 }}"
                >
                  {{ block.settings.button_label_2 | escape }}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .valor-rich-text {
    padding-top: var(--valor-section-padding-top, 56px);
    padding-bottom: var(--valor-section-padding-bottom, 56px);
    background-color: var(--color-background);
    color: var(--color-foreground);
  }
  .valor-rich-text__inner {
    width: 100%;
    max-width: 75rem;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem);
    display: flex;
  }
  /* Position the content block within the inner container */
  .valor-rich-text--pos-left .valor-rich-text__inner {
    justify-content: flex-start;
  }
  .valor-rich-text--pos-center .valor-rich-text__inner {
    justify-content: center;
  }
  .valor-rich-text--pos-right .valor-rich-text__inner {
    justify-content: flex-end;
  }

  .valor-rich-text__content {
    max-width: 38rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .valor-rich-text--full-width .valor-rich-text__content {
    max-width: none;
    width: 100%;
  }

  .valor-rich-text--align-left .valor-rich-text__content {
    text-align: left;
    align-items: flex-start;
  }
  .valor-rich-text--align-center .valor-rich-text__content {
    text-align: center;
    align-items: center;
  }
  .valor-rich-text--align-right .valor-rich-text__content {
    text-align: right;
    align-items: flex-end;
  }

  .valor-rich-text__caption {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
    font-weight: 500;
  }
  .valor-rich-text__caption--small {
    font-size: 0.75rem;
  }
  .valor-rich-text__caption--medium {
    font-size: 0.875rem;
  }
  .valor-rich-text__caption--large {
    font-size: 1rem;
  }

  .valor-rich-text__text {
    font-size: 1rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-foreground) 85%, transparent);
  }
  .valor-rich-text__text > *:first-child {
    margin-top: 0;
  }
  .valor-rich-text__text > *:last-child {
    margin-bottom: 0;
  }

  .valor-rich-text__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .valor-rich-text--align-center .valor-rich-text__buttons {
    justify-content: center;
  }
  .valor-rich-text--align-right .valor-rich-text__buttons {
    justify-content: flex-end;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Rich text",
  "tag": "section",
  "class": "valor-section-rich-text",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "label": "Position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Talk about your brand"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading size",
          "options": [
            {
              "value": "small",
              "label": "Small"
            },
            {
              "value": "medium",
              "label": "Medium"
            },
            {
              "value": "large",
              "label": "Large"
            }
          ],
          "default": "medium"
        }
      ]
    },
    {
      "type": "caption",
      "name": "Caption",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "Add a tagline"
        },
        {
          "type": "select",
          "id": "text_size",
          "label": "Caption size",
          "options": [
            {
              "value": "small",
              "label": "Small"
            },
            {
              "value": "medium",
              "label": "Medium"
            },
            {
              "value": "large",
              "label": "Large"
            }
          ],
          "default": "medium"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "label": "Button 1 label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button 1 link",
          "info": "The button is hidden until both a label and a link are set. Use the picker to choose a page, product, collection, or paste a custom URL."
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button 1 style",
          "options": [
            { "value": "primary", "label": "Solid" },
            { "value": "secondary", "label": "Outline" },
            { "value": "link", "label": "Text link" }
          ],
          "default": "primary"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Button 2 label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Button 2 link",
          "info": "The button is hidden until both a label and a link are set."
        },
        {
          "type": "select",
          "id": "button_style_2",
          "label": "Button 2 style",
          "options": [
            { "value": "primary", "label": "Solid" },
            { "value": "secondary", "label": "Outline" },
            { "value": "link", "label": "Text link" }
          ],
          "default": "secondary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rich text",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "buttons"
        }
      ]
    }
  ]
}
{% endschema %}
