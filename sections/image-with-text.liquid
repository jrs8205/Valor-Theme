{%- liquid
  assign image_width = section.settings.desktop_image_width
  assign layout = section.settings.layout
  assign desktop_position = section.settings.desktop_content_position
  assign desktop_alignment = section.settings.desktop_content_alignment
  assign mobile_alignment = section.settings.mobile_content_alignment

  assign image_loading = 'lazy'
  assign image_fetchpriority = 'auto'
  if section.location == 'template' and section.index == 1
    assign image_loading = 'eager'
    assign image_fetchpriority = 'high'
  endif
-%}
<section
  class="color-{{ section.settings.color_scheme }} valor-iwt valor-iwt--image-{{ image_width }} valor-iwt--{{ layout }} valor-iwt--height-{{ section.settings.height }}"
  style="--valor-section-padding-top: {{ section.settings.padding_top }}px; --valor-section-padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="valor-iwt__inner">
    <div class="valor-iwt__media">
      {%- if section.settings.image != blank -%}
        {%- assign img = section.settings.image -%}
        <img
          class="valor-iwt__image"
          srcset="{{ img | image_url: width: 400 }} 400w, {{ img | image_url: width: 600 }} 600w, {{ img | image_url: width: 800 }} 800w, {{ img | image_url: width: 1100 }} 1100w, {{ img | image_url: width: 1500 }} 1500w"
          src="{{ img | image_url: width: 800 }}"
          sizes="(min-width: 750px) 50vw, 100vw"
          alt="{{ img.alt | escape }}"
          width="{{ img.width }}"
          height="{{ img.height }}"
          loading="{{ image_loading }}"
          fetchpriority="{{ image_fetchpriority }}"
        >
      {%- else -%}
        <div class="valor-iwt__placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'valor-iwt__placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    <div class="valor-iwt__content valor-iwt__content--pos-{{ desktop_position }} valor-iwt__content--align-{{ desktop_alignment }} valor-iwt__content--mobile-{{ mobile_alignment }}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h2
              class="valor-iwt__heading valor-heading valor-heading--{{ block.settings.heading_size }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.heading }}
            </h2>
          {%- when 'caption' -%}
            <div
              class="valor-iwt__caption valor-iwt__caption--{{ block.settings.text_size }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.caption | escape }}
            </div>
          {%- when 'text' -%}
            <div class="valor-iwt__text rte" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>
          {%- when 'button' -%}
            {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
              <div class="valor-iwt__button-wrap" {{ block.shopify_attributes }}>
                <a
                  href="{{ block.settings.button_link }}"
                  class="valor-button valor-button--{{ block.settings.button_style }}"
                >
                  {{ block.settings.button_label | escape }}
                </a>
              </div>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .valor-iwt {
    padding-top: var(--valor-section-padding-top, 56px);
    padding-bottom: var(--valor-section-padding-bottom, 56px);
    background-color: var(--color-background);
    color: var(--color-foreground);
  }
  .valor-iwt__inner {
    width: 100%;
    max-width: 75rem;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  /* Media */
  .valor-iwt__media {
    overflow: hidden;
    background-color: color-mix(in srgb, var(--color-foreground) 4%, transparent);
  }
  .valor-iwt__image,
  .valor-iwt__placeholder {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
  .valor-iwt__placeholder-svg {
    width: 100%;
    height: auto;
  }

  /* Heights — sets media aspect ratio */
  .valor-iwt--height-small .valor-iwt__media {
    aspect-ratio: 4 / 3;
  }
  .valor-iwt--height-medium .valor-iwt__media {
    aspect-ratio: 1 / 1;
  }
  .valor-iwt--height-large .valor-iwt__media {
    aspect-ratio: 4 / 5;
  }
  .valor-iwt--height-adapt .valor-iwt__media {
    aspect-ratio: auto;
  }
  .valor-iwt--height-small .valor-iwt__image,
  .valor-iwt--height-medium .valor-iwt__image,
  .valor-iwt--height-large .valor-iwt__image,
  .valor-iwt--height-small .valor-iwt__placeholder,
  .valor-iwt--height-medium .valor-iwt__placeholder,
  .valor-iwt--height-large .valor-iwt__placeholder {
    height: 100%;
    object-fit: cover;
  }

  /* Content */
  .valor-iwt__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .valor-iwt__content--pos-top {
    justify-content: flex-start;
  }
  .valor-iwt__content--pos-middle {
    justify-content: center;
  }
  .valor-iwt__content--pos-bottom {
    justify-content: flex-end;
  }
  .valor-iwt__content--align-left {
    text-align: left;
    align-items: flex-start;
  }
  .valor-iwt__content--align-center {
    text-align: center;
    align-items: center;
  }
  .valor-iwt__content--align-right {
    text-align: right;
    align-items: flex-end;
  }

  .valor-iwt__caption {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
    font-weight: 500;
  }
  .valor-iwt__caption--small {
    font-size: 0.75rem;
  }
  .valor-iwt__caption--medium {
    font-size: 0.875rem;
  }
  .valor-iwt__caption--large {
    font-size: 1rem;
  }

  .valor-iwt__text {
    font-size: 1rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-foreground) 85%, transparent);
  }
  .valor-iwt__text > *:first-child {
    margin-top: 0;
  }
  .valor-iwt__text > *:last-child {
    margin-bottom: 0;
  }

  .valor-iwt__button-wrap {
    margin-top: 0.5rem;
  }

  /* Desktop layout — side by side. The media-width settings explicitly
     target the media column so they work the same regardless of order. */
  @media (min-width: 750px) {
    .valor-iwt__inner {
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 5rem);
      align-items: stretch;
    }
    /* Image first (default DOM order): media in column 1 */
    .valor-iwt--image-small.valor-iwt--image_first .valor-iwt__inner {
      grid-template-columns: 1fr 2fr;
    }
    .valor-iwt--image-large.valor-iwt--image_first .valor-iwt__inner {
      grid-template-columns: 2fr 1fr;
    }

    /* Text first: visually swap by reordering, AND swap the column widths so
       "Small image" still means small image in either layout. */
    .valor-iwt--text_first .valor-iwt__media {
      order: 2;
    }
    .valor-iwt--image-small.valor-iwt--text_first .valor-iwt__inner {
      grid-template-columns: 2fr 1fr;
    }
    .valor-iwt--image-large.valor-iwt--text_first .valor-iwt__inner {
      grid-template-columns: 1fr 2fr;
    }
  }

  /* Mobile alignment override */
  @media (max-width: 749px) {
    .valor-iwt__content--mobile-left {
      text-align: left;
      align-items: flex-start;
    }
    .valor-iwt__content--mobile-center {
      text-align: center;
      align-items: center;
    }
    .valor-iwt__content--mobile-right {
      text-align: right;
      align-items: flex-end;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Image with text",
  "tag": "section",
  "class": "valor-section-image-with-text",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Image height",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "small",
          "label": "Small (4:3)"
        },
        {
          "value": "medium",
          "label": "Medium (1:1)"
        },
        {
          "value": "large",
          "label": "Large (4:5)"
        }
      ],
      "default": "medium"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "desktop_image_width",
      "label": "Desktop image width",
      "options": [
        {
          "value": "small",
          "label": "Small (1/3)"
        },
        {
          "value": "medium",
          "label": "Medium (1/2)"
        },
        {
          "value": "large",
          "label": "Large (2/3)"
        }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "image_first",
          "label": "Image first"
        },
        {
          "value": "text_first",
          "label": "Text first"
        }
      ],
      "default": "image_first"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "label": "Vertical position",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "middle",
          "label": "Middle"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "middle"
    },
    {
      "type": "select",
      "id": "desktop_content_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Mobile layout"
    },
    {
      "type": "select",
      "id": "mobile_content_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Image with text"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading size",
          "options": [
            {
              "value": "small",
              "label": "Small"
            },
            {
              "value": "medium",
              "label": "Medium"
            },
            {
              "value": "large",
              "label": "Large"
            }
          ],
          "default": "medium"
        }
      ]
    },
    {
      "type": "caption",
      "name": "Caption",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "Add a tagline"
        },
        {
          "type": "select",
          "id": "text_size",
          "label": "Caption size",
          "options": [
            {
              "value": "small",
              "label": "Small"
            },
            {
              "value": "medium",
              "label": "Medium"
            },
            {
              "value": "large",
              "label": "Large"
            }
          ],
          "default": "medium"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            { "value": "primary", "label": "Solid" },
            { "value": "secondary", "label": "Outline" },
            { "value": "link", "label": "Text link" }
          ],
          "default": "primary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with text",
      "blocks": [
        {
          "type": "caption"
        },
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}
