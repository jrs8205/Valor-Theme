{%- comment -%}
  Password section.

  Renders the landing page shown when password protection is applied
  to a store (Online Store → Preferences → Password protection). The
  page lives outside the normal header/footer chrome — it uses
  layout/password.liquid which only loads critical.css plus this
  section, so styling has to be self-contained.

  Layout: vertically centered card with the shop logo (or shop name
  fallback), an opening heading, the merchant's password message, and
  the password form. A small footer line links back to the admin login
  for the merchant themselves.
{%- endcomment -%}

{%- liquid
  assign heading_size = section.settings.heading_size | default: 'large'
  assign body_size = section.settings.body_size | default: 'medium'
  assign show_message = section.settings.show_message
-%}

<div class="color-{{ section.settings.color_scheme }} valor-password">
  <div class="valor-password__inner">
    <header class="valor-password__header">
      {%- if section.settings.logo != blank -%}
        {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
        {%- assign logo_max = section.settings.logo_width | default: 160 -%}
        <a href="{{ routes.root_url }}" class="valor-password__logo-link" aria-label="{{ shop.name | escape }}">
          {{
            section.settings.logo
            | image_url: width: 600
            | image_tag:
              loading: 'eager',
              width: section.settings.logo.width,
              height: section.settings.logo.height,
              alt: logo_alt,
              class: 'valor-password__logo',
              style: 'max-width:'
            | append: logo_max
            | append: 'px'
          }}
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}" class="valor-password__shop-name valor-heading valor-heading--medium">
          {{ shop.name | escape }}
        </a>
      {%- endif -%}
    </header>

    <h1 class="valor-password__heading valor-heading valor-heading--{{ heading_size }}">
      {{ 'password.opening_soon' | t | default: 'Opening soon' }}
    </h1>

    {%- if show_message and shop.password_message != blank -%}
      <div class="valor-password__message valor-password__message--body-{{ body_size }} rte">
        {{ shop.password_message }}
      </div>
    {%- endif -%}

    <div class="valor-password__form-wrap">
      <p class="valor-password__form-label">
        {{ 'password.enter_password' | t | default: 'Enter store using password:' }}
      </p>

      {%- form 'storefront_password' -%}
        <div class="valor-password__form-row">
          <input
            type="password"
            name="password"
            id="ValorPasswordInput"
            class="valor-password__input"
            autocomplete="current-password"
            aria-label="{{ 'password.password' | t | default: 'Password' }}"
            placeholder="{{ 'password.password' | t | default: 'Password' }}"
          >
          <button type="submit" class="valor-button valor-button--primary valor-password__submit">
            {{ 'password.enter' | t | default: 'Enter' }}
          </button>
        </div>

        {%- if form.errors -%}
          <p class="valor-password__error" role="alert">
            {{ form.errors.translated_fields.form }}
            {{ form.errors.messages.form }}
          </p>
        {%- endif -%}
      {%- endform -%}
    </div>

    <footer class="valor-password__footer">
      <p class="valor-password__admin-link">
        {{ 'password.admin_link_html' | t | default: 'Are you the store owner? <a href="/admin">Log in here</a>' }}
      </p>
    </footer>
  </div>
</div>

{% stylesheet %}
  .valor-password {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1.5rem, 5vw, 4rem) clamp(1rem, 4vw, 3rem);
    background-color: var(--color-background);
    color: var(--color-foreground);
    box-sizing: border-box;
  }

  .valor-password__inner {
    width: 100%;
    max-width: 32rem;
    text-align: center;
  }

  .valor-password__header {
    margin-bottom: 2rem;
  }

  .valor-password__logo {
    height: auto;
    width: 100%;
    margin: 0 auto;
  }

  .valor-password__shop-name {
    display: inline-block;
    text-decoration: none;
    color: inherit;
  }

  .valor-password__heading {
    margin: 0 0 1rem;
    line-height: 1.2;
  }

  .valor-password__message {
    margin: 0 0 2rem;
    color: color-mix(in srgb, var(--color-foreground) 85%, transparent);
  }
  .valor-password__message--body-small {
    font-size: var(--font-size-body-sm);
  }
  .valor-password__message--body-medium {
    font-size: var(--font-size-body-base);
  }
  .valor-password__message--body-large {
    font-size: var(--font-size-body-lg);
  }

  .valor-password__message > :first-child {
    margin-top: 0;
  }
  .valor-password__message > :last-child {
    margin-bottom: 0;
  }

  .valor-password__form-wrap {
    margin-bottom: 2.5rem;
  }

  .valor-password__form-label {
    margin: 0 0 0.75rem;
    font-size: var(--font-size-body-sm);
    color: color-mix(in srgb, var(--color-foreground) 85%, transparent);
  }

  .valor-password__form-row {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
  }

  .valor-password__input {
    flex: 1 1 auto;
    min-width: 0;
    padding: 0.75rem 1rem;
    border: 1px solid var(--valor-border-strong);
    border-radius: var(--style-border-radius-inputs, 4px);
    background-color: var(--color-background);
    color: var(--color-foreground);
    font-family: var(--font-body--family);
    font-size: var(--font-size-body-base);
    line-height: 1.4;
    box-sizing: border-box;
  }
  .valor-password__input::placeholder {
    color: color-mix(in srgb, var(--color-foreground) 75%, transparent);
  }
  .valor-password__input:focus {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .valor-password__submit {
    flex: 0 0 auto;
    white-space: nowrap;
  }

  .valor-password__error {
    margin: 0.75rem 0 0;
    font-size: var(--font-size-body-sm);
    color: var(--valor-color-error);
  }

  .valor-password__footer {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--valor-border-default);
  }

  .valor-password__admin-link {
    margin: 0;
    font-size: var(--font-size-body-sm);
    color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
  }
  .valor-password__admin-link a {
    color: inherit;
    text-decoration: underline;
  }

  /* Mobile: stack the input and button vertically so the button isn't
     squashed against the input on narrow screens. */
  @media (max-width: 480px) {
    .valor-password__form-row {
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Password page",
  "tag": "section",
  "class": "valor-section-password",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Shown above the heading. If empty, the shop name is shown instead."
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo max width",
      "min": 80,
      "max": 320,
      "step": 8,
      "unit": "px",
      "default": 160
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "large"
    },
    {
      "type": "checkbox",
      "id": "show_message",
      "label": "Show password message",
      "info": "Set the message under Online Store → Preferences → Password protection.",
      "default": true
    },
    {
      "type": "select",
      "id": "body_size",
      "label": "Message body size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    }
  ]
}
{% endschema %}
