{{ 'product-info.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-info.js' | asset_url }}" defer></script>

{%- comment -%}
  Main product section.

  This is the section used by templates/product.json. It renders the
  media gallery alongside merchant-configurable info blocks (title,
  price, variant picker, buy buttons, etc.).

  Structure:
    - Block-level rendering for the more complex blocks (price, sku,
      inventory, variant_picker, quantity_selector, buy_buttons, share,
      rating, collapsible_tab, popup) lives in shared snippets under
      snippets/product-*.liquid.
    - Simple blocks (@app, vendor, text, title, description,
      custom_liquid) render inline because they're trivial 1-5 line
      HTML and don't benefit from the indirection.
    - Component-level CSS (price, variants, quantity, rating,
      collapsible, popup, etc.) lives in assets/product-info.css.
      Section-level layout CSS (wrapper, grid, media column, sticky
      info) stays in this file's {% stylesheet %}.
    - All interactive JS lives in assets/product-info.js as a
      <product-info> custom element. The info column is wrapped in
      that element so the script's connectedCallback() can find its
      own scope without DOM traversal from a section-id selector.
{%- endcomment -%}

{%- liquid
  assign sticky = section.settings.enable_sticky_info
  assign media_width = section.settings.media_width
  assign media_position = section.settings.media_position
  assign media_fit = section.settings.media_fit
  assign media_aspect = section.settings.media_aspect_ratio
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id

  # Resolve gallery overrides: section-level 'default' falls back to the
  # theme-wide setting so merchants can configure a global preference and
  # then opt in/out per product page. Same pattern as featured-product.
  assign enable_lightbox = settings.gallery_enable_lightbox
  if section.settings.enable_lightbox == 'on'
    assign enable_lightbox = true
  elsif section.settings.enable_lightbox == 'off'
    assign enable_lightbox = false
  endif

  assign show_thumbnails = settings.gallery_show_thumbnails
  if section.settings.show_thumbnails == 'on'
    assign show_thumbnails = true
  elsif section.settings.show_thumbnails == 'off'
    assign show_thumbnails = false
  endif

  assign show_arrows = settings.gallery_show_arrows
  if section.settings.show_arrows == 'on'
    assign show_arrows = true
  elsif section.settings.show_arrows == 'off'
    assign show_arrows = false
  endif

  assign mobile_indicator = settings.gallery_mobile_indicator | default: 'counter'
  if section.settings.mobile_indicator != 'default'
    assign mobile_indicator = section.settings.mobile_indicator
  endif
  assign desktop_gallery_layout = section.settings.desktop_gallery_layout | default: 'single'

  assign use_inline_size_guide = false
  for candidate_block in section.blocks
    if candidate_block.type == 'variant_picker' and candidate_block.settings.size_option_style == 'minimal'
      assign use_inline_size_guide = true
      break
    endif
  endfor

  assign inline_size_guide_block = null
  if use_inline_size_guide
    for candidate_block in section.blocks
      if candidate_block.type == 'popup' and candidate_block.settings.display_style == 'inline_size'
        assign inline_size_guide_block = candidate_block
        break
      endif
    endfor
  endif
-%}

<section
  class="valor-mp valor-mp--media-{{ media_width }} valor-mp--media-{{ media_position }}{% if sticky %} valor-mp--sticky{% endif %}{% if section.settings.image_size_mobile == 'full' %} valor-mp--image-full-mobile{% endif %}"
  style="--valor-section-padding-top: {{ section.settings.padding_top }}px; --valor-section-padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-section-id="{{ section.id }}"
>
  <div class="valor-mp__inner">
    <div class="valor-mp__media" data-mp-gallery="{{ section.id }}">
      {%- render 'product-media-gallery',
        product: product,
        section_id: section.id,
        aspect: media_aspect,
        enable_lightbox: enable_lightbox,
        show_thumbnails: show_thumbnails,
        show_arrows: show_arrows,
        mobile_indicator: mobile_indicator,
        desktop_layout: desktop_gallery_layout,
        media_fit: media_fit,
        priority: true
      -%}
    </div>

    <product-info
      class="valor-mp__info"
      data-section-id="{{ section.id }}"
      data-product-id="{{ product.id }}"
      data-product-url="{{ product.url }}"
      data-money-format="{{ shop.money_format | escape }}"
    >
      <script type="application/json" data-product-info-i18n>
        {
          "addToCart":       {{ 'product.add_to_cart'       | t | json }},
          "soldOut":         {{ 'product.sold_out'          | t | json }},
          "sale":            {{ 'product.sale'              | t | json }},
          "sku":             {{ 'product.sku'               | t | json }},
          "inCart":          {{ 'product.in_cart'           | t | json }},
          "inCartCount":     {{ 'product.in_cart_count'     | t | json }},
          "inCartOf":        {{ 'product.in_cart_of'        | t | json }},
          "totalInCart":     {{ 'product.total_in_cart'     | t | json }},
          "inStock":         {{ 'product.in_stock'          | t | json }},
          "lowStock":        {{ 'product.low_stock'         | t | json }},
          "lowStockCount":   {{ 'product.low_stock_count'   | t | json }},
          "outOfStock":      {{ 'product.out_of_stock'      | t | json }},
          "shareLinkCopied": {{ 'product.share_link_copied' | t | json }}
        }
      </script>
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {%- render block -%}

          {%- when 'vendor' -%}
            {%- if product.vendor != blank -%}
              <p
                class="valor-mp__vendor valor-mp__vendor--{{ block.settings.text_style }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.show_as_link -%}
                  <a href="{{ product.vendor | url_for_vendor }}">{{ product.vendor }}</a>
                {%- else -%}
                  {{ product.vendor }}
                {%- endif -%}
              </p>
            {%- endif -%}

          {%- when 'text' -%}
            {%- if block.settings.text != blank -%}
              <p
                class="valor-mp__text valor-mp__text--{{ block.settings.text_style }}"
                {{ block.shopify_attributes }}
              >
                {{- block.settings.text -}}
              </p>
            {%- endif -%}

          {%- when 'title' -%}
            <h1
              class="valor-mp__title valor-heading valor-heading--{{ block.settings.heading_size | default: 'medium' }}"
              {{ block.shopify_attributes }}
            >
              {{- product.title | escape -}}
            </h1>

          {%- when 'price' -%}
            {%- render 'product-price', variant: current_variant, block: block -%}

          {%- when 'payment_terms' -%}
            {%- assign payment_terms_form_id = 'payment-terms-'
              | append: section.id
              | append: '-'
              | append: block.id
            -%}
            {%- render 'product-payment-terms',
              product: product,
              variant: current_variant,
              block: block,
              form_id: payment_terms_form_id
            -%}

          {%- when 'sku' -%}
            {%- render 'product-sku', variant: current_variant, block: block -%}

          {%- when 'inventory' -%}
            {%- render 'product-inventory', variant: current_variant, block: block -%}

          {%- when 'variant_picker' -%}
            {%- render 'product-variant-picker',
              product: product,
              block: block,
              section_id: section.id,
              class_prefix: 'valor-mp',
              swatch_shape: block.settings.swatch_shape,
              swatch_size: block.settings.swatch_size,
              size_guide_block: inline_size_guide_block
            -%}

          {%- when 'quantity_selector' -%}
            {%- render 'product-quantity',
              product: product,
              variant: current_variant,
              block: block,
              section_id: section.id,
              form_id: product_form_id
            -%}

          {%- when 'buy_buttons' -%}
            {%- render 'product-buy-buttons',
              product: product,
              variant: current_variant,
              block: block,
              form_id: product_form_id,
              section: section
            -%}

          {%- when 'pickup_availability' -%}
            {%- render 'product-pickup-availability', variant: current_variant, block: block, section: section -%}

          {%- when 'complementary' -%}
            {%- render 'complementary-products', block: block, product: product, section_id: section.id -%}

          {%- when 'description' -%}
            {%- if product.description != blank -%}
              <div class="valor-mp__description rte" {{ block.shopify_attributes }}>
                {{ product.description }}
              </div>
            {%- endif -%}

          {%- when 'share' -%}
            {%- render 'product-share', block: block -%}

          {%- when 'rating' -%}
            {%- render 'product-rating', product: product, block: block -%}

          {%- when 'collapsible_tab' -%}
            {%- render 'product-collapsible-tab', block: block -%}

          {%- when 'popup' -%}
            {%- liquid
              assign render_popup_block = true
              if inline_size_guide_block != blank and block.settings.display_style == 'inline_size'
                assign render_popup_block = false
              endif
            -%}
            {%- if render_popup_block -%}
              {%- render 'product-popup', block: block, section_id: section.id -%}
            {%- endif -%}

          {%- when 'custom_liquid' -%}
            {%- if block.settings.custom_liquid != blank -%}
              <div class="valor-mp__custom-liquid" {{ block.shopify_attributes }}>
                {{ block.settings.custom_liquid }}
              </div>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </product-info>
  </div>

  {%- if section.settings.enable_sticky_add_to_cart -%}
    {%- liquid
      assign sticky_media = current_variant.featured_media | default: product.featured_media
      assign sticky_variant_title = current_variant.title
      if product.has_only_default_variant
        assign sticky_variant_title = blank
      endif
    -%}
    <div
      class="valor-mp__sticky-atc"
      data-sticky-atc
      data-section-id="{{ section.id }}"
      hidden
    >
      <div class="valor-mp__sticky-atc-inner">
        <div class="valor-mp__sticky-atc-product">
          {%- if sticky_media != blank -%}
            <span class="valor-mp__sticky-atc-media">
              {{
                sticky_media
                | image_url: width: 160
                | image_tag:
                  loading: 'lazy',
                  widths: '80, 120, 160',
                  sizes: '4rem',
                  class: 'valor-mp__sticky-atc-image',
                  alt: sticky_media.alt
              }}
            </span>
          {%- endif -%}
          <span class="valor-mp__sticky-atc-copy">
            <span class="valor-mp__sticky-atc-title">{{ product.title | escape }}</span>
            <span class="valor-mp__sticky-atc-variant" data-sticky-variant-title>
              {{- sticky_variant_title -}}
            </span>
          </span>
        </div>

        <div class="valor-mp__sticky-atc-actions">
          <div class="valor-mp__sticky-atc-price" data-sticky-price>
            <span class="valor-mp__sticky-atc-price-current">{{ current_variant.price | money }}</span>
            {%- if current_variant.compare_at_price > current_variant.price -%}
              <s class="valor-mp__sticky-atc-price-compare">{{ current_variant.compare_at_price | money }}</s>
            {%- endif -%}
          </div>
          <button
            type="submit"
            form="{{ product_form_id }}"
            class="valor-button valor-button--primary valor-mp__sticky-atc-button"
            {% unless current_variant.available %}
              disabled
            {% endunless %}
            data-sticky-add-button
          >
            <span data-sticky-add-button-text>
              {%- if current_variant.available -%}
                {{ 'product.add_to_cart' | t }}
              {%- else -%}
                {{ 'product.sold_out' | t }}
              {%- endif -%}
            </span>
          </button>
        </div>
      </div>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  /* === Section wrapper === */
  .valor-mp {
    padding-top: var(--valor-section-padding-top, 36px);
    padding-bottom: var(--valor-section-padding-bottom, 36px);
    background-color: var(--color-background);
    color: var(--color-foreground);
  }

  /* === Inner grid: media + info ===
     Mobile: single column, media on top, info below.
     Desktop: 2 columns whose ratio depends on media_width, optionally
     swapped with --media-right. */
  .valor-mp__inner {
    width: 100%;
    max-width: 75rem;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 750px) {
    .valor-mp__inner {
      gap: 3rem;
      align-items: start;
    }
    /* Media size = the relative width of the media column.
       small  → media is smallest (1/3), info column is widest
       medium → media and info are roughly equal
       large  → media is largest (2/3), info column is narrowest
       Same convention as Dawn and as Valor's featured-product.

       For media-right, the grid-template-columns are simply reversed —
       this gives the media column the same width as in media-left, just
       on the other side. Reversing the column definitions keeps the
       selected media width paired with the selected media side. */
    .valor-mp--media-left.valor-mp--media-small .valor-mp__inner {
      grid-template-columns: minmax(0, 0.35fr) minmax(0, 0.65fr);
    }
    .valor-mp--media-left.valor-mp--media-medium .valor-mp__inner {
      grid-template-columns: minmax(0, 0.5fr) minmax(0, 0.5fr);
    }
    .valor-mp--media-left.valor-mp--media-large .valor-mp__inner {
      grid-template-columns: minmax(0, 0.65fr) minmax(0, 0.35fr);
    }

    .valor-mp--media-right.valor-mp--media-small .valor-mp__inner {
      grid-template-columns: minmax(0, 0.65fr) minmax(0, 0.35fr);
    }
    .valor-mp--media-right.valor-mp--media-medium .valor-mp__inner {
      grid-template-columns: minmax(0, 0.5fr) minmax(0, 0.5fr);
    }
    .valor-mp--media-right.valor-mp--media-large .valor-mp__inner {
      grid-template-columns: minmax(0, 0.35fr) minmax(0, 0.65fr);
    }

    /* Right-side media: swap visual order without changing source order */
    .valor-mp--media-right .valor-mp__media {
      order: 2;
    }
  }

  /* === Media column === */
  .valor-mp__media {
    width: 100%;
    min-width: 0; /* Prevent grid blowout from oversized children */
  }

  /* Full-width image on mobile — stretches ONLY the main image
     edge-to-edge while thumbnails and product info stay within the
     section's padding.

     Theme shell wraps every section in a CSS grid where children are
     constrained to the center column (.shopify-section > * { grid-column: 2 }).
     A negative margin alone can only compensate the section's own padding,
     not the grid's center column, so we first promote the section to
     span the full grid (grid-column: 1 / -1), then apply the classic
     full-bleed trick (width: 100vw + margin-left: calc(50% - 50vw)) to
     the main image element itself. Same approach as featured-product. */
  @media (max-width: 749px) {
    .shopify-section > .valor-mp--image-full-mobile {
      grid-column: 1 / -1;
    }
    .valor-mp--image-full-mobile .valor-product-media__main {
      width: 100vw;
      max-width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }
    .valor-mp--image-full-mobile .valor-product-media__progress {
      width: 100vw;
      max-width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }
  }

  /* === Info column ===
     Sticky on desktop only — on mobile the info naturally appears below
     the gallery and sticky behaviour would just confuse the scroll.

     Sticky implementation: position: sticky + align-self: start. The
     info column stays anchored near the top of the viewport while the
     media column scrolls past it. We deliberately don't constrain
     max-height or set overflow-y: auto — that would make the info
     column scroll *internally* (a separate scrollbar inside the
     content), which is what the previous version did and feels
     broken from the customer's perspective. With sticky alone, if
     the info is taller than the viewport, the page scrolls naturally
     once the customer reaches the bottom of the info — a much more
     intuitive interaction. */
  .valor-mp__info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  @media (min-width: 990px) {
    .valor-mp--sticky .valor-mp__info {
      position: sticky;
      /* Falls back to 5rem when --valor-header-height is not yet defined.
         Future header refactor can populate the variable for pixel-accurate
         offset. */
      top: calc(var(--valor-header-height, 5rem) + 1rem);
      align-self: start;
    }
  }

  /* Component-level styles (text, title, price, sku, vendor, inventory,
     variants, quantity, buy-buttons, description, share) live in
     assets/product-info.css so they can be shared across product
     sections. Layout-only rules — section wrapper, grid, media column,
     image-full-mobile, info column flex + sticky — stay in this file. */
  .valor-mp__sticky-atc {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 110;
    padding: 0.75rem clamp(1rem, 4vw, 3rem) calc(0.75rem + env(safe-area-inset-bottom, 0px));
    background-color: var(--color-background);
    color: var(--color-foreground);
    border-top: 1px solid color-mix(in srgb, var(--color-foreground) 12%, transparent);
    box-shadow: 0 -0.75rem 2rem color-mix(in srgb, var(--color-foreground) 9%, transparent);
    transform: translateY(110%);
    transition: transform 0.22s ease;
  }
  .valor-mp__sticky-atc.is-visible {
    transform: translateY(0);
  }
  .valor-mp__sticky-atc-inner {
    width: min(100%, 75rem);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .valor-mp__sticky-atc-product {
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .valor-mp__sticky-atc-media {
    flex: 0 0 3.75rem;
    width: 3.75rem;
    height: 3.75rem;
    background-color: color-mix(in srgb, var(--color-foreground) 4%, transparent);
  }
  .valor-mp__sticky-atc-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .valor-mp__sticky-atc-copy {
    min-width: 0;
    display: grid;
    gap: 0.15rem;
  }
  .valor-mp__sticky-atc-title,
  .valor-mp__sticky-atc-variant {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .valor-mp__sticky-atc-title {
    font-weight: var(--font-body--weight-bold);
  }
  .valor-mp__sticky-atc-variant {
    font-size: 0.875rem;
    color: color-mix(in srgb, var(--color-foreground) 68%, transparent);
  }
  .valor-mp__sticky-atc-variant:empty {
    display: none;
  }
  .valor-mp__sticky-atc-actions {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .valor-mp__sticky-atc-price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    white-space: nowrap;
  }
  .valor-mp__sticky-atc-price-current {
    font-weight: var(--font-body--weight-bold);
  }
  .valor-mp__sticky-atc-price-compare {
    color: color-mix(in srgb, var(--color-foreground) 55%, transparent);
  }
  .valor-mp__sticky-atc-button {
    min-width: 10rem;
  }
  @media (max-width: 749px) {
    .valor-mp__sticky-atc {
      padding-inline: 0.75rem;
    }
    .valor-mp__sticky-atc-inner {
      align-items: stretch;
      gap: 0.75rem;
    }
    .valor-mp__sticky-atc-media,
    .valor-mp__sticky-atc-price {
      display: none;
    }
    .valor-mp__sticky-atc-product {
      flex: 1 1 auto;
    }
    .valor-mp__sticky-atc-actions {
      flex: 0 0 auto;
    }
    .valor-mp__sticky-atc-button {
      min-width: 8.5rem;
      height: 100%;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .valor-mp__sticky-atc {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product information",
  "tag": "section",
  "class": "valor-section-main-product",
  "blocks": [
    { "type": "@app" },
    {
      "type": "vendor",
      "name": "Vendor",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "text_style",
          "options": [
            { "value": "body", "label": "Body" },
            { "value": "subtitle", "label": "Subtitle" },
            { "value": "uppercase", "label": "Uppercase" }
          ],
          "default": "uppercase",
          "label": "Text style"
        },
        {
          "type": "checkbox",
          "id": "show_as_link",
          "default": false,
          "label": "Link to vendor collection"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "Text block",
          "label": "Text"
        },
        {
          "type": "select",
          "id": "text_style",
          "options": [
            { "value": "body", "label": "Body" },
            { "value": "subtitle", "label": "Subtitle" },
            { "value": "uppercase", "label": "Uppercase" }
          ],
          "default": "body",
          "label": "Text style"
        }
      ]
    },
    {
      "type": "title",
      "name": "Title",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading size",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "medium", "label": "Medium" },
            { "value": "large", "label": "Large" }
          ],
          "default": "medium"
        }
      ]
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "price_font_size",
          "min": 12,
          "max": 64,
          "step": 1,
          "unit": "px",
          "default": 24,
          "label": "t:sections.main_product.blocks.price.settings.price_font_size.label"
        }
      ]
    },
    {
      "type": "payment_terms",
      "name": "t:sections.main_product.blocks.payment_terms.name",
      "limit": 1,
      "settings": []
    },
    {
      "type": "sku",
      "name": "SKU",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "text_style",
          "options": [
            { "value": "body", "label": "Body" },
            { "value": "subtitle", "label": "Subtitle" },
            { "value": "uppercase", "label": "Uppercase" }
          ],
          "default": "body",
          "label": "Text style"
        }
      ]
    },
    {
      "type": "inventory",
      "name": "Inventory status",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "inventory_threshold",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 10,
          "label": "Low-stock threshold",
          "info": "Show \"Low stock\" when inventory is at or below this number."
        },
        {
          "type": "checkbox",
          "id": "show_inventory_quantity",
          "default": true,
